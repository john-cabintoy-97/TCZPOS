@using TCZPOS.Components.Services.Hardware;
@using TCZPOS.Components.Extension;
@inject AlertServices alertService
@implements IDisposable

@if (_config != null)
{
    @* Added pointer-events-auto so buttons can be clicked *@
    <div class="fixed top-10 left-1/2 -translate-x-1/2 z-[200] pointer-events-auto transition-all duration-300">
        <div class="flex flex-col items-center gap-3 p-1 animate-pop-in">
            @if (_config.IconOnly)
            {
                @* --- ICON ONLY MODE --- *@
                <div class="h-16 w-16 flex items-center justify-center rounded-2xl bg-white shadow-2xl border-2 @GetBorderColor() text-3xl @GetTextColor()">
                    <i class="@_config.Icon"></i>
                </div>
            }
            else
            {
                @* --- FULL MESSAGE MODE --- *@
                <div class="flex flex-col bg-white border-l-4 @GetBorderColor() px-6 py-4 rounded-xl shadow-2xl min-w-[320px]">
                    <div class="flex items-center gap-4">
                        <i class="@_config.Icon text-xl @GetTextColor()"></i>
                        <div class="flex flex-col">
                            <span class="text-[9px] font-black uppercase tracking-widest text-slate-400">System Alert</span>
                            <span class="text-xs font-bold text-slate-700">@_config.Message</span>
                        </div>
                    </div>

                    @if (_config.IsConfirm)
                    {
                        @* --- CONFIRMATION BUTTONS --- *@
                        <div class="flex justify-end items-center gap-4 mt-4 border-t pt-3">
                            @* Use w-fit and px-4 so the button size adjusts to the text length *@
                            <button @onclick="() => HandleChoice(false)"
                                    class="w-fit px-2 py-2 text-[10px] font-bold uppercase tracking-wider text-slate-400 hover:text-slate-600">
                                @_config.CancelText
                            </button>
        
                            <button @onclick="() => HandleChoice(true)"
                                    class="w-fit px-4 py-2 bg-slate-800 text-white rounded-lg text-[10px] font-bold uppercase tracking-wider shadow-md active:scale-95 transition-all whitespace-nowrap">
                                @_config.ConfirmText
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private AlertType? _config;
    private System.Timers.Timer? _timer;

    protected override void OnInitialized() => alertService.OnShow += HandleShow;

    private void HandleShow(AlertType config)
    {
        _config = config;
        InvokeAsync(StateHasChanged);

        _timer?.Stop();

        // ONLY start the auto-close timer if it's NOT a confirmation.
        // We don't want the "View File" button to vanish while they are looking at it!
        if (!_config.IsConfirm)
        {
            _timer = new System.Timers.Timer(2500);
            _timer.Elapsed += (s, e) => { _config = null; InvokeAsync(StateHasChanged); };
            _timer.AutoReset = false;
            _timer.Start();
        }
    }

    private async Task HandleChoice(bool confirmed)
    {
        if (_config?.ConfirmTask != null)
        {
            // This signals the ExportToPdf function to resume
            _config.ConfirmTask.TrySetResult(confirmed);
        }

        // Close the alert immediately after choice
        _config = null;
        await InvokeAsync(StateHasChanged);
    }

    private string GetBorderColor() => _config?.Type switch
    {
        AlertTypeList.Success => "border-emerald-500",
        AlertTypeList.Error => "border-red-500",
        AlertTypeList.Warning => "border-orange-500",
        _ => "border-blue-500"
    };

    private string GetTextColor() => _config?.Type switch
    {
        AlertTypeList.Success => "text-emerald-500",
        AlertTypeList.Error => "text-red-500",
        AlertTypeList.Warning => "text-orange-500",
        _ => "text-blue-500"
    };

    public void Dispose() { alertService.OnShow -= HandleShow; _timer?.Dispose(); }
}