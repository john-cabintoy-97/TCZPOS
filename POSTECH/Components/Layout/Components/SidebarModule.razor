@using TCZPOS.Components.Scanner
@inject TranslationService Trans

<ul class="m-0 list-none p-0">
    @foreach (var item in MenuItems)
    {
        if (!HasPermission(item)) continue;
        @if (item.SubItems == null || !item.SubItems.Any())
        {
            <li>
                @* 1. Check if this is the Scanner button *@
                @if (item.Id == "wireless-scanner-btn")
                {
                    <button @onclick="OnScannerClick"
                            type="button"
                            class="mt-2 mb-2 flex w-full items-center gap-4 rounded-lg px-4 py-2 text-gray-300 transition-all hover:bg-gray-500 hover:text-yellow-100">
                        <i class="@item.Icon @item.IconColor text-lg"></i>
                        <span>@Trans.T(item.Text)</span>
                    </button>
                }
                else if (item.Id == "pairing-scanner")
                {
                    <ScannerNavButton Label="@Trans.T(item.Text)"
                                      Icon="@item.Icon"
                                      ShowManual="false"
                                      IconClass='@($"{item.IconColor} text-lg")'
                                      ScanMode="PAIRING"
                                      OnScanResult="HandlePairingResult"
                                      class="mt-2 mb-2 flex w-full items-center gap-4 rounded-lg px-4 py-2 text-gray-300 transition-all hover:bg-gray-500 hover:text-yellow-100" />
                }
                else
                {
                    @* Normal Navigation Link *@
                    <NavLink href="@item.Href"
                             Match="NavLinkMatch.All"
                             class="mt-2 mb-2 flex items-center gap-4 rounded-lg px-4 py-2 text-gray-300 hover:bg-gray-500 hover:text-yellow-100"
                             ActiveClass="bg-gray-500 text-white">
                        <i class="@item.Icon @item.IconColor text-lg"></i>
                        <span>@Trans.T(item.Text)</span>
                    </NavLink>
                }
            </li>
        }
        else
        {
            @* Submenu Logic stays the same *@
            <li>
                <button @onclick="() => Toggle(item.Id)"
                        class="w-full flex items-center justify-between px-4 py-2 mt-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white">
                    <div class="flex items-center gap-3">
                        <i class="@item.Icon @item.IconColor text-lg"></i>
                        <span>@Trans.T(item.Text)</span>
                    </div>
                    <svg xmlns="http://www.w3.org/2000/svg"
                         class="h-4 w-4 transition-transform @(IsOpen(item.Id) ? "rotate-180" : "")"
                         fill="none" stroke="currentColor" stroke-width="2"
                         viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>

                @if (IsOpen(item.Id))
                {
                    <ul class="mt-1 ml-6 space-y-1">
                        @foreach (var sub in item.SubItems)
                        {
                            <li>
                                <NavLink href="@sub.Href"
                                         class="block rounded-md px-4 py-2 text-sm text-gray-400 hover:bg-gray-500 hover:text-white"
                                         ActiveClass="bg-gray-500 text-white">
                                    @Trans.T(sub.Text)
                                </NavLink>
                            </li>
                        }
                    </ul>
                }
            </li>
        }
    }
</ul>

@code {
    [Parameter] public StaffModels? ActiveStaff { get; set; }
    [Parameter] public EventCallback OnScannerClick { get; set; }
    [Parameter] public EventCallback<string> HandlePairingResult { get; set; }
    [Parameter] public List<NavMenuItem> MenuItems { get; set; } = new();

    private bool HasPermission(NavMenuItem item)
    {
        // 1. If no roles are specified, the menu is public (accessible to all)
        if (item.AllowedRoles == null || !item.AllowedRoles.Any())
            return true;

        // 2. The Owner (Master Account) bypasses all checks and sees everything
        if (ActiveStaff?.Role == StaffRole.Owner)
            return true;

        // 3. Check if the Active Staff's current role is in the allowed list
        // We use .ToString() to match your StaffRole Enum to the string list
        var currentRoleName = ActiveStaff?.Role.ToString();
        
        return !string.IsNullOrEmpty(currentRoleName) &&
               item.AllowedRoles.Contains(currentRoleName);
    }


    private string? _openMenuId;

    private void Toggle(string id)
    {
        if (string.IsNullOrEmpty(id)) return;
        
        // If clicking the already open menu, close it. Otherwise, open the new one.
        if (_openMenuId == id)
            _openMenuId = null;
        else
            _openMenuId = id;
    }

    private bool IsOpen(string id) => _openMenuId == id;
}