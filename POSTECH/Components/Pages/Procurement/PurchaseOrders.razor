@page "/procurement/orders"
@using TCZPOS.Components.Models
@using TCZPOS.Components.Services.Hardware
@using TCZPOS.Components.Services
@inject VendorServices vendorServices
@inject OrderServices orderServices
@inject AlertServices alertServices
@inject NavigationManager nav
@inject ProductServices productService

<div class="flex h-screen w-full flex-col overflow-hidden font-sans text-white bg-[#0F172A]">
    @* Reuse your Header Logic here *@
    <div class="flex flex-col bg-[#1A252F] p-4 shadow-xl lg:flex-row lg:items-center lg:justify-between lg:gap-4">
        <div class="flex items-center gap-3 pb-3 lg:pb-0">
            <h2 class="text-xl font-bold text-white uppercase tracking-tight">Purchase <span class="text-orange-500">Orders</span></h2>
        </div>
        <div class="mb-3 h-px w-full bg-slate-800 lg:hidden"></div>

        <div class="flex items-center justify-between gap-3 lg:flex-none lg:justify-end">
            <span class="rounded border border-orange-500/20 bg-orange-500/10 px-2 py-1 text-xs text-orange-500">
                Total Classifications
            </span>
            <span class="text-3xl font-black text-orange-500">@orderServices.OrderList.Count</span>
        </div>
    </div>
    <div class="flex flex-col border-b bg-white">
        <div class="flex flex-col gap-4 p-4 md:flex-row md:items-center md:justify-between">
            <div class="flex flex-1 items-center gap-3">
                <div class="flex flex-1 max-w-md overflow-hidden rounded-xl border border-slate-300 bg-white shadow-sm focus-within:border-orange-500 focus-within:ring-1 focus-within:ring-orange-500/20">
                    <input type="text" @bind="SearchTerm" @bind:event="oninput"
                           class="w-full text-slate-800 px-4 py-2 text-sm font-medium outline-none"
                           placeholder="Quick search ..." />
                    <div class="flex items-center bg-slate-50 px-3 border-l border-slate-200 text-slate-400">
                        <i class="fas fa-search text-xs"></i>
                    </div>
                </div>
            
                <button @onclick="OpenCreateOrderModal"
                        class="flex h-[40px] items-center gap-2 rounded-xl bg-slate-900 px-5 font-black text-[10px] uppercase tracking-widest text-white shadow-lg transition-all hover:bg-orange-600 active:scale-95">
                    <i class="fas fa-plus"></i>
                    <span class="hidden sm:inline"> Create Purchase Order</span>
                </button>
            </div>

            <div class="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0">
                <button @onclick='() => SetFilter("All")'
                        class="whitespace-nowrap rounded-full px-4 py-1.5 text-[10px] font-bold uppercase transition-all @(_activeFilter == "All" ? "bg-orange-500 text-white" : "bg-white border border-slate-200 text-slate-500")">
                    All
                </button>
                <button @onclick='() => SetFilter("Recent")'
                        class="whitespace-nowrap rounded-full px-4 py-1.5 text-[10px] font-bold uppercase transition-all @(_activeFilter == "Recent" ? "bg-orange-500 text-white" : "bg-white border border-slate-200 text-slate-500")">
                    Recently Added
                </button>
            </div>
        </div>

        <div class="flex items-center gap-1 border-t border-slate-200 bg-white px-4 py-1.5">
            <span class="mr-2 text-[9px] font-black uppercase tracking-tighter text-slate-400">Index:</span>
            <div class="flex flex-1 items-center gap-0.5 overflow-x-auto no-scrollbar">
                <button @onclick='() => SetLetter("All")'
                        class="px-2 py-1 text-[10px] font-bold @(_selectedLetter == "All" ? "text-orange-600 underline" : "text-slate-400 hover:text-slate-900")">
                    All
                </button>
                @foreach (var letter in "ABCDEFGHIJKLMNOPQRSTUVWXYZ")
                {
                    var l = letter.ToString();
                    <button @onclick="() => SetLetter(l)"
                            class="min-w-[24px] px-1 py-1 text-[10px] font-bold transition-colors @(_selectedLetter == l ? "rounded bg-orange-100 text-orange-700" : "text-slate-400 hover:text-slate-900")">
                        @l
                    </button>
                }
            </div>
        
            @if (_selectedLetter != "All" || _activeFilter != "All" || !string.IsNullOrEmpty(_searchTerm))
            {
                <button @onclick="ClearAllFilters" class="ml-2 text-[9px] font-black text-red-500 uppercase hover:text-red-700">
                    Reset
                </button>
            }
        </div>
    </div>
           
    @* Table Section for Orders *@
    <div class="flex-1 overflow-auto  bg-white text-slate-800">
        <GenericTable TItem="PurchaseOrderModels"
                      Items="PagedData.ToList()"
                      TableTitle="Purchase Order Records"
                      TotalCount="FilteredData.Count()"
                      PageSize="_pageSize"
                      CurrentPage="_currentPage"
                      ShowSelection="false"
                      OnPageChanged="HandlePageChange"
                      SearchTerm="@_searchTerm">
            <TableHeader>
                @* --- MOBILE HEADER (Visible only on small screens) --- *@
                <th class="md:hidden px-4 py-3 text-left text-[10px] uppercase font-black tracking-widest text-slate-400">
                    Order Details
                </th>
                        
                @* --- DESKTOP HEADERS (Hidden on mobile, visible on md and up) --- *@
                <th class="hidden md:table-cell px-6 py-3 font-black text-[10px] uppercase tracking-widest text-slate-400">
                    PO Number
                </th>
                <th class="hidden md:table-cell px-6 py-3 font-black text-[10px] uppercase tracking-widest text-slate-400">
                    Vendor
                </th>
                <th class="hidden md:table-cell px-6 py-3 font-black text-[10px] uppercase tracking-widest text-slate-400">
                    Total
                </th>
                <th class="hidden md:table-cell px-6 py-3 font-black text-[10px] uppercase tracking-widest text-slate-400">
                    Status
                </th>
                <th class="hidden md:table-cell px-6 py-3 font-black text-[10px] uppercase text-right tracking-widest text-slate-400">
                    Actions
                </th>
            </TableHeader>
            <RowTemplate Context="po">
                @* --- DESKTOP VIEW (Visible on medium screens and up) --- *@
                <td class="hidden md:table-cell px-6 py-4 font-bold text-slate-700">@po.Item.OrderNumber</td>
                <td class="hidden md:table-cell px-6 py-4 text-slate-600">@po.Item.VendorName</td>
                <td class="hidden md:table-cell px-6 py-4 text-orange-600 font-bold">₱ @po.Item.TotalAmount.ToString("N2")</td>
                <td class="hidden md:table-cell px-6 py-4">
                    <span class="px-2 py-1 rounded-full text-[10px] font-bold @(po.Item.Status == "Pending" ? "bg-yellow-100 text-yellow-700" : "bg-green-100 text-green-700")">
                        @po.Item.Status
                    </span>
                </td>
                <td class="hidden md:table-cell px-6 py-4 text-right">
                    <div class="flex items-center justify-end gap-3">
                        @if (po.Item.Status == "Pending")
                        {
                            <button @onclick="() => HandleCompleteOrder(po.Item)"
                                    class="text-green-500 hover:text-green-700 transition-transform active:scale-95"
                                    title="Mark as Received">
                                <i class="fas fa-check-double"></i>
                            </button>
                        }
                        <button @onclick="() => PreviewPO(po.Item)" class="text-blue-500 hover:text-blue-700">
                            <i class="fas fa-eye text-lg"></i>
                        </button>
                        <button @onclick="() => HandleDelete(po.Item)" class="text-red-500 hover:text-red-700">
                            <i class="fas fa-trash text-lg"></i>
                        </button>
                    </div>
                </td>

                @* --- MOBILE VIEW (Card Layout - Visible only on small screens) --- *@
                <td colspan="5" class="md:hidden p-3 border-b-4 border-slate-100 bg-white">
                    <div class="flex flex-col gap-4">
                        @* Status & Date *@
                        <div class="flex justify-between items-center py-2 px-3 bg-slate-50 rounded-lg border border-slate-100">
                            <div>
                                <p class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">Status</p>
                                <span class="text-[10px] font-black uppercase @(po.Item.Status == "Pending" ? "text-yellow-600" : "text-emerald-600")">
                                    @po.Item.Status
                                </span>
                            </div>
                            <div class="text-right">
                                <p class="text-[9px] uppercase font-bold text-slate-400 tracking-wider">PO Reference</p>
                                <p class="text-xs font-mono font-bold text-slate-700 uppercase">@po.Item.OrderNumber</p>
                            </div>
                        </div>

                        @* Vendor and Amount *@
                        <div class="flex justify-between items-start">
                            <div class="flex flex-col gap-1">
                                <h4 class="font-black text-slate-900 text-sm leading-tight uppercase tracking-tight">
                                    @po.Item.VendorName
                                </h4>
                                <div class="flex flex-wrap gap-1">
                                    <span class="bg-slate-100 text-slate-500 font-mono text-[10px] px-1.5 py-0.5 rounded uppercase">
                                        @po.Item.OrderDate.ToString("MMM dd, yyyy")
                                    </span>
                                </div>
                            </div>
                            <div class="text-right flex flex-col items-end">
                                <div class="text-[10px] text-slate-400 uppercase font-black mb-1">Total Amount</div>
                                <span class="text-xl font-black font-mono text-orange-600">
                                    ₱@po.Item.TotalAmount.ToString("N2")
                                </span>
                            </div>
                        </div>

                        @* Actions Footer *@
                        <div class="flex justify-between items-center pt-2 border-t border-slate-50">
                            <div class="flex gap-2">
                                @if (po.Item.Status == "Pending")
                                {
                                    <button @onclick="() => HandleCompleteOrder(po.Item)"
                                            class="flex items-center justify-center w-10 h-10 bg-green-50 text-green-600 rounded-full active:scale-95">
                                        <i class="fas fa-check-double"></i>
                                    </button>
                                }
                                <button @onclick="() => HandleDelete(po.Item)"
                                        class="flex items-center justify-center w-10 h-10 bg-red-50 text-red-500 rounded-full active:scale-95">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                
                            <button @onclick="() => PreviewPO(po.Item)"
                                    class="flex items-center justify-center px-4 h-10 bg-orange-50 text-orange-600 rounded-full font-bold text-xs uppercase gap-2 active:scale-95 transition-all">
                                <i class="fas fa-eye"></i>
                                View Details
                            </button>
                        </div>
                    </div>
                </td>
            </RowTemplate>
        </GenericTable>
    </div>
</div>

@if (_showOrderModal)
{
    <Modal IsVisible="_showOrderModal"
           Title="New Purchase Order"
           OnClose="() => _showOrderModal = false"
           OnConfirm="HandleSaveOrder">
        <ChildContent>
            @* Changed to White Base BG *@
            <div class="p-4 space-y-6 bg-white text-slate-800 rounded-b-xl">
                
                @* 1. Vendor Selection *@
                <div class="space-y-1">
                    <label class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Supplier / Vendor</label>
                    <ComboBox TItem="VendorModels"
                              BgClass="!p-2"
                              TValue="int"
                              Items="_vendors"
                              @bind-Value="_activeOrder.VendorId"
                              ValueSelector="@(v => v.Id)"
                              SearchSelector="@(v => v.Name)"
                              OnQuickAdd='() => nav.NavigateTo("/procurement/vendors")'>
                        <ItemTemplate>
                            <span class="text-slate-700">@context.Name</span>
                        </ItemTemplate>
                    </ComboBox>
                </div>

                @* 2. Item Entry Row *@
                <div class="space-y-2 border-t border-slate-100 pt-4">
                    <label class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Add Products</label>
    
                    @* Container now uses 'flex-col' to stack the two rows *@
                    <div class="flex flex-col gap-3 ">
        
                        @* ROW 1: Full Width Product Search *@
                        <div class="w-full">
                            <ComboBox TItem="ProductModels"
                                      TValue="int"
                                      Placeholder="Search for a product to add..."
                                      ContainerClass="w-full"
                                      BgClass="!p-2"
                                      Items="productService.ProductDisplayList.Select(x => x.Product).ToList()"
                                      ValueSelector="@(p => p.Id)"
                                      SearchSelector="@(p => p.Name)"
                                      Value="_selectedProductId"
                                      ValueChanged="OnProductPicked"
                                      OnQuickAdd='() => nav.NavigateTo("/inventory/products")'>
                                <ItemTemplate>
                                    <div class="flex justify-between w-full">
                                        <span class="text-slate-700 font-medium">@context.Name</span>
                                        <span class="text-[10px] text-slate-400">@context.Barcode</span>
                                    </div>
                                </ItemTemplate>
                            </ComboBox>
                        </div>

                       @* Updated Row 2: Qty and Button *@
                        <div class="flex flex-col sm:grid sm:grid-cols-2 gap-3">
                            @* Quantity - Full width on mobile, half on tablet/desktop *@
                            <div class="relative flex items-center">
                                <span class="absolute left-4 text-[10px] font-black text-slate-400 uppercase tracking-tighter">Quantity</span>
                                <input @bind="_newItem.QuantityOrdered"
                                       type="number"
                                       inputmode="decimal" 
                                       class="w-full h-[50px] bg-white border border-slate-200 pl-20 pr-4 rounded-xl text-sm font-bold text-slate-800 outline-none" />
                            </div>

                            @* Add Button - Full width on mobile *@
                            <button @onclick="AddItemToOrder"
                                    class="w-full h-[50px] bg-orange-500 hover:bg-orange-600 rounded-xl font-black uppercase text-[11px] text-white shadow-lg transition-all active:scale-95 flex items-center justify-center gap-2">
                                <i class="fas fa-cart-plus"></i>
                                Add to Summary
                            </button>
                        </div>
                    </div>
                </div>
                @* 3. Order Items List *@
                <div class="space-y-3">
                    <div class="flex justify-between items-center">
                        <label class="text-[10px] uppercase font-black text-slate-400 tracking-widest">Order Summary</label>
                        <span class="text-[10px] font-bold px-2 py-0.5 bg-orange-100 text-orange-600 rounded-full">@_activeOrder.Items.Count Items</span>
                    </div>
                    
                    <div class="max-h-48 overflow-y-auto space-y-2 pr-1 custom-scrollbar">
                        @if (!_activeOrder.Items.Any())
                        {
                            <div class="text-center py-8 border-2 border-dashed border-slate-100 rounded-2xl bg-slate-50/50">
                                <i class="fas fa-shopping-cart text-slate-200 mb-2"></i>
                                <p class="text-[10px] text-slate-400 uppercase font-bold">No items in queue</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var item in _activeOrder.Items)
                            {
                                <div class="flex justify-between items-center p-3 bg-white border border-slate-100 rounded-xl shadow-sm">
                                    <div class="flex flex-col">
                                        <span class="font-bold text-slate-700">@item.ProductName</span>
                                        <span class="text-[10px] text-slate-400">Qty: @item.QuantityOrdered × ₱@item.UnitCost.ToString("N2")</span>
                                    </div>
                                    <div class="flex items-center gap-4">
                                        <span class="text-orange-600 font-black">₱@item.SubTotal.ToString("N2")</span>
                                        <button @onclick="() => RemoveItem(item)" class="text-slate-300 hover:text-red-500 transition-colors">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                @* 4. Footer Total *@
                @if (_activeOrder.Items.Any())
                {
                    <div class="flex justify-between items-center bg-slate-900 p-4 rounded-xl">
                        <span class="text-[10px] font-black uppercase text-slate-400">Total Payable</span>
                        <span class="text-xl font-black text-white">₱ @_activeOrder.TotalAmount.ToString("N2")</span>
                    </div>
                }
            </div>
        </ChildContent>
    </Modal>
}

@if (_showDetailsModal && _selectedOrder != null)
{
    <Modal IsVisible="_showDetailsModal"
           Title="Purchase Order Details"
           ShowFooter="false"
           customCss="!rounded-br-[15px] !rounded-bl-[15px]"
           OnClose="() => _showDetailsModal = false">
        <ChildContent>
            <div class="flex flex-col gap-4 p-5 font-sans text-slate-800 bg-white min-h-[400px]">
                
                @* Header Section *@
                <div class="flex justify-between items-start border-b border-dashed border-slate-200 pb-4">
                    <div>
                        <h3 class="text-[10px] font-black uppercase text-slate-400 tracking-widest">PO Number</h3>
                        <p class="text-lg font-mono font-bold text-orange-600">@_selectedOrder.OrderNumber</p>
                    </div>
                    <div class="text-right">
                        <span class="@(_selectedOrder.Status == "Pending" ? "bg-yellow-100 text-yellow-700" : "bg-emerald-100 text-emerald-700") px-3 py-1 rounded-full text-[10px] font-black uppercase">
                            @_selectedOrder.Status
                        </span>
                        <p class="text-[10px] text-slate-400 mt-1 font-mono uppercase">@_selectedOrder.OrderDate.ToString("MMM dd, yyyy hh:mm tt")</p>
                    </div>
                </div>

                @* Vendor Info *@
                <div class="bg-slate-50 p-3 rounded-xl border border-slate-100">
                    <p class="text-[9px] font-black uppercase text-slate-400">Supplier</p>
                    <p class="text-sm font-bold text-slate-700">@_selectedOrder.VendorName</p>
                </div>

                @* Items List *@
                <div>
                    <p class="text-[10px] font-black uppercase text-slate-400 mb-3 tracking-widest">Items Ordered</p>
                    <div class="flex flex-wrap gap-2 max-h-48 overflow-y-auto pr-1">
                        @if (_selectedOrder.Items != null && _selectedOrder.Items.Any())
                        {
                            @foreach (var item in _selectedOrder.Items)
                            {
                                <div class="flex items-center gap-2 bg-white border border-slate-200 px-3 py-1.5 rounded-full shadow-sm">
                                    <span class="flex h-5 min-w-[1.25rem] px-1 shrink-0 items-center justify-center rounded-full bg-slate-800 text-[9px] font-black text-white">
                                        @item.QuantityOrdered
                                    </span>
                    
                                    <span class="text-xs font-bold text-slate-700 whitespace-nowrap">@item.ProductName</span>
                    
                                    <div class="flex items-center gap-1.5 ml-1 pl-2 border-l border-slate-200">
                                        <span class="text-[9px] font-medium text-slate-400">
                                            @@ ₱@item.UnitCost.ToString("N2")
                                        </span>
                                        <i class="fas fa-arrow-right text-[8px] text-slate-300"></i>
                                        <span class="font-mono text-[11px] font-black text-orange-600">
                                            ₱@item.SubTotal.ToString("N2")
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                @* Totals Summary *@
                <div class="mt-auto pt-4 border-t-2 border-slate-100">
                    <div class="flex justify-between text-sm text-slate-500 font-medium">
                        <span>Grand Total</span>
                        <span>₱@_selectedOrder.TotalAmount.ToString("N2")</span>
                    </div>
                    <div class="flex justify-between text-lg font-black text-slate-900 pt-2">
                        <span>TOTAL AMOUNT</span>
                        <span class="text-orange-600">₱@_selectedOrder.TotalAmount.ToString("N2")</span>
                    </div>

                    @if (_selectedOrder.Status == "Completed")
                    {
                        <div class="mt-3 flex items-center justify-center gap-2 bg-emerald-50 text-emerald-700 p-2 rounded-lg border border-emerald-100">
                            <i class="fas fa-check-circle text-xs"></i>
                            <span class="text-[9px] font-black uppercase tracking-wider">Inventory has been updated</span>
                        </div>
                    }
                </div>
            </div>
        </ChildContent>
    </Modal>
}

@code {
    private List<PurchaseOrderModels> _orders = new();
    private List<VendorModels> _vendors = new();
    private PurchaseOrderModels _activeOrder = new();
    private PurchaseOrderItemModels _newItem = new();
    private PurchaseOrderModels? _selectedOrder;
    private int _selectedProductId;

    private int _currentPage = 1;
    private int _pageSize = 10;
    private string _selectedLetter = "All";
    private string _activeFilter = "All";
    private string _searchTerm = "";
    private bool _showOrderModal, _showDetailsModal;

    private bool IsFiltered => _selectedLetter != "All" || _activeFilter != "All" || !string.IsNullOrEmpty(_searchTerm);

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(vendorServices.LoadAsync(), productService.LoadProductsAsync(), RefreshOrders());
        _vendors = vendorServices.DataList;
    }
    private void OnProductPicked(int id)
    {
        _selectedProductId = id;
        HandleProductSelected(id);
    }
    private void RemoveItem(PurchaseOrderItemModels item)
    {
        _activeOrder.Items.Remove(item);
        _activeOrder.TotalAmount = _activeOrder.Items.Sum(x => x.SubTotal);
        StateHasChanged();
    }
    private string SearchTerm
    {
        get => _searchTerm;
        set { if (_searchTerm != value) { _searchTerm = value; _currentPage = 1; StateHasChanged(); } }
    }

    private async Task RefreshOrders()
    {
        // 1. Fetch fresh data from service
        _orders = await orderServices.GetAllOrdersAsync();
    
        // 2. Recalculate pagination bounds immediately
        var totalCount = FilteredData.Count();
        var maxPage = (int)Math.Ceiling((double)totalCount / _pageSize);
        if (maxPage < 1) maxPage = 1;
    
        // 3. If the current page is now empty (e.g., after a delete), move back
        if (_currentPage > maxPage)
        {
            _currentPage = maxPage;
        }

        // 4. Force Blazor to re-evaluate PagedData and re-render the table
        StateHasChanged();
    }
    private void SetLetter(string letter) { _selectedLetter = letter; _currentPage = 1; }
    private void SetFilter(string filter) { _activeFilter = filter; _currentPage = 1; }
    private void ClearAllFilters() { _searchTerm = ""; _selectedLetter = "All"; _activeFilter = "All"; _currentPage = 1; }

    private IEnumerable<PurchaseOrderModels> FilteredData => _orders
     .Where(x => _activeFilter switch
     {
         "All" => x.Status == "Pending",
         "ToReceive" => x.Status == "Pending",
         "Recent" => x.OrderDate >= DateTime.Now.AddDays(-7) && x.Status == "Pending",
         "History" => x.Status == "Completed",
         _ => true
     })
     .Where(x => string.IsNullOrWhiteSpace(_searchTerm)
                 || x.OrderNumber.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)
                 || x.VendorName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
     .Where(x => _selectedLetter == "All"
                 || x.VendorName.StartsWith(_selectedLetter, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<PurchaseOrderModels> PagedData => FilteredData.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);

    private void OpenCreateOrderModal()
    {
        _activeOrder = new PurchaseOrderModels
        {
            OrderNumber = $"PO-{DateTime.Now:yyyyMMdd}-{_orders.Count + 1}",
            OrderDate = DateTime.Now,
            Status = "Pending"
        };
        _showOrderModal = true;
    }

    private void HandleProductSelected(int productId)
    {
        var product = productService.ProductDisplayList.FirstOrDefault(p => p.Product.Id == productId)?.Product;
        if (product != null)
        {
            _newItem.ProductId = product.Id;
            _newItem.ProductName = product.Name;
            _newItem.UnitCost = product.CostPrice;
        }
    }

    private void AddItemToOrder()
    {
        if (_newItem.ProductId == 0 || _newItem.QuantityOrdered <= 0) return;
    
        _activeOrder.Items.Add(new PurchaseOrderItemModels
        {
            ProductId = _newItem.ProductId,
            ProductName = _newItem.ProductName,
            QuantityOrdered = _newItem.QuantityOrdered,
            UnitCost = _newItem.UnitCost
        });

        _activeOrder.TotalAmount = _activeOrder.Items.Sum(x => x.SubTotal);
        _selectedProductId = 0;
        _newItem = new(); // Reset input fields
    
        StateHasChanged(); // Refresh the modal list view
    }

    private async Task HandleSaveOrder()
    {
        if (_activeOrder.VendorId == 0 || !_activeOrder.Items.Any()) return;
        _activeOrder.VendorName = _vendors.FirstOrDefault(v => v.Id == _activeOrder.VendorId)?.Name ?? "Unknown";

        if ((await orderServices.SaveOrderAsync(_activeOrder)).Success)
        {
            _showOrderModal = false;
            await RefreshOrders();
            StateHasChanged();
            alertServices.Success("Order Saved");
        }
    }

    private async Task HandleCompleteOrder(PurchaseOrderModels order)
    {
        if (await alertServices.ConfirmAsync("Receive items?"))
        {
            var response = await orderServices.UpdateOrderStatusAsync(order);
        
            if (response.Success)
            {
                await RefreshOrders();
                alertServices.Success(response.Message);
            }
            else
            {
                alertServices.Warning(response.Message);
            }
        }
    }
    private async Task HandleDelete(PurchaseOrderModels order)
    {
        bool confirmed = await alertServices.ConfirmAsync($"Are you sure you want to delete {order.OrderNumber}?");
    
        if (confirmed)
        {
            // 2. Optional: Add a safety check for Completed orders
            if (order.Status == "Completed")
            {
                bool secondConfirm = await alertServices.ConfirmAsync("This order is marked as COMPLETED. Deleting it may cause discrepancies in your history. Proceed anyway?");
                if (!secondConfirm) return;
            }

            // 3. Call the service
            var response = await orderServices.DeleteOrderAsync(order.Id);
        
            if (response.Success)
            {
                alertServices.Success(response.Message);
                await RefreshOrders(); // This triggers the UI update and pagination reset
            }
            else
            {
                alertServices.Error(response.Message);
            }
        }
    }
    private void HandlePageChange(int newPage)
    {
        var maxPage = (int)Math.Ceiling((double)FilteredData.Count() / _pageSize);

        if (maxPage < 1) maxPage = 1;

        if (newPage >= 1 && newPage <= maxPage)
        {
            _currentPage = newPage;
            StateHasChanged();
        }
    }
    private async Task PreviewPO(PurchaseOrderModels po)
    {
        _selectedOrder = await orderServices.GetOrderByIdAsync(po.Id);
        _showDetailsModal = _selectedOrder != null;
    }
}