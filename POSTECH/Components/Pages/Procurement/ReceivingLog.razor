    private async Task GeneratePDFReport()
    {
        try
        {
            if (_orderToPrint == null) return;

            using var document = new PdfDocument();
            var page = document.AddPage();
            var gfx = XGraphics.FromPdfPage(page);
        
            // Define Fonts
            var fontTitle = new XFont("Arial", 16, XFontStyle.Bold);
            var fontHeader = new XFont("Arial", 10, XFontStyle.Bold);
            var fontRegular = new XFont("Arial", 10, XFontStyle.Regular);
            var fontSmall = new XFont("Arial", 8, XFontStyle.Regular);

            // 1. Header Section
            gfx.DrawString("INVENTORY RECEIVING REPORT", fontTitle, XBrushes.Black, new XRect(0, 40, page.Width, 20), XStringFormats.TopCenter);
        
            int currentY = 80;
            gfx.DrawString($"PO Reference: {_orderToPrint.OrderNumber}", fontRegular, XBrushes.Black, 50, currentY);
            gfx.DrawString($"Date: {_orderToPrint.OrderDate:MMM dd, yyyy}", fontRegular, XBrushes.Black, 400, currentY);
        
            currentY += 20;
            gfx.DrawString($"Vendor: {_orderToPrint.VendorName}", fontRegular, XBrushes.Black, 50, currentY);

            // 2. Items Table Header
            currentY += 40;
            gfx.DrawRectangle(XPens.SlateGray, XBrushes.GhostWhite, 50, currentY - 15, page.Width - 100, 20);
            gfx.DrawString("Product Description", fontHeader, XBrushes.Black, 60, currentY);
            gfx.DrawString("Qty", fontHeader, XBrushes.Black, 300, currentY);
            gfx.DrawString("Unit Cost", fontHeader, XBrushes.Black, 360, currentY);
            gfx.DrawString("Subtotal", fontHeader, XBrushes.Black, 450, currentY);

            // 3. Draw Items
            currentY += 20;
            if (_orderToPrint.Items != null)
            {
                foreach (var item in _orderToPrint.Items)
                {
                    // Basic check for page overflow (optional: simplified for now)
                    gfx.DrawString(item.ProductName ?? "Unknown Item", fontRegular, XBrushes.DarkSlateGray, 60, currentY);
                    gfx.DrawString(item.QuantityOrdered.ToString(), fontRegular, XBrushes.Black, 300, currentY);
                    gfx.DrawString($"P {item.UnitCost:N2}", fontRegular, XBrushes.Black, 360, currentY);
                    gfx.DrawString($"P {item.SubTotal:N2}", fontRegular, XBrushes.Black, 450, currentY);
                
                    currentY += 15;
                    // Draw a very light separator line
                    gfx.DrawLine(XPens.LightGray, 50, currentY - 5, page.Width - 50, currentY - 5);
                    currentY += 5;
                }
            }

            // 4. Summary Totals
            currentY += 20;
            gfx.DrawLine(XPens.Black, 350, currentY, page.Width - 50, currentY);
            currentY += 20;
            gfx.DrawString("TOTAL AMOUNT RECEIVED:", fontHeader, XBrushes.Black, 300, currentY);
            gfx.DrawString($"PHP {_orderToPrint.TotalAmount:N2}", fontTitle, XBrushes.DarkOrange, 450, currentY);

            // Save and Export
            using var stream = new MemoryStream();
            document.Save(stream, false);
            var fileData = stream.ToArray();

            var fileName = $"Receiving_{_orderToPrint.OrderNumber}_{DateTime.Now:yyyyMMdd}.pdf";
            await FileSaver.SaveAsync(fileName, new MemoryStream(fileData));
        
            _showPrintModal = false;
            alertServices.Notify("PDF Generated Successfully", AlertTypeList.Success);
        }
        catch (Exception ex)
        {
            alertServices.Notify($"PDF Error: {ex.Message}", AlertTypeList.Error);
        }
    }
}