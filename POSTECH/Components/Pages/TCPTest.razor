@page "/test"
@implements IDisposable
@inject ConnectionStateProvider State
@inject TCPClientServices TcpService

<div class="mx-auto flex h-[calc(100vh-4rem)] max-w-2xl flex-col bg-gray-900 p-4 text-white">
    
    @* Connection Status Badge *@
    @if (State.IsPaired)
    {
        <div class="mb-4 flex items-center gap-3 rounded-xl border border-emerald-500/20 bg-emerald-500/10 px-4 py-3">
            <div class="relative flex h-3 w-3">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex h-3 w-3 rounded-full bg-emerald-500"></span>
            </div>
            <p class="text-sm font-medium text-emerald-400">
                Linked to PC: <span class="font-mono text-white">@State.IpAddress:@State.Port</span>
            </p>
        </div>
    }

    @* Chat Log Container *@
    <div class="custom-scrollbar mb-4 flex-1 space-y-3 overflow-y-auto rounded-2xl border border-gray-700 bg-gray-800/40 p-4">
        @if (!chatLog.Any())
        {
            <div class="flex h-full flex-col items-center justify-center text-gray-600 opacity-50">
                <i class="fas fa-terminal mb-2 text-3xl"></i>
                <p class="text-xs font-bold tracking-widest uppercase">Waiting for logs...</p>
            </div>
        }

        @foreach (var msg in chatLog)
        {
            bool isMe = msg.StartsWith("You:");
            <div class="animate-in @(isMe ? "justify-end" : "justify-start") fade-in slide-in-from-bottom-1 flex duration-300">
                <div class="max-w-[85%] rounded-2xl px-4 py-2 text-sm shadow-sm @(isMe ? "bg-blue-600 text-white rounded-br-none" : "bg-gray-700 text-gray-100 rounded-bl-none")">
                    @msg.Replace("You: ", "")
                </div>
            </div>
        }
    </div>

    @* Controls Section *@
    <div class="space-y-3 rounded-2xl border border-gray-700 bg-gray-800 p-4 shadow-2xl">
        @* Connection Details (Visible for debugging) *@
        <div class="grid grid-cols-2 gap-3">
            <div class="relative">
                <span class="absolute top-2.5 left-3 font-black text-[10px] text-gray-500 uppercase">IP Host</span>
                <input @bind="State.IpAddress" class="w-full rounded-lg border border-gray-700 bg-gray-950 py-2 pr-3 pl-14 text-sm text-blue-400 transition-all outline-none focus:border-yellow-500" />
            </div>
            <div class="relative">
                <span class="absolute top-2.5 left-3 font-black text-[10px] text-gray-500 uppercase">Port</span>
                <input @bind="State.Port" type="number" class="w-full rounded-lg border border-gray-700 bg-gray-950 py-2 pr-3 pl-12 text-sm text-blue-400 transition-all outline-none focus:border-yellow-500" />
            </div>
        </div>

        @* Message Input *@
        <div class="flex gap-2">
            <input @bind="userMessage" @bind:event="oninput" @onkeyup="HandleKeyUp"
                   placeholder="Type a test message..."
                   class="flex-1 rounded-xl border border-gray-700 bg-gray-950 px-4 py-3 text-white shadow-inner transition-all outline-none placeholder:text-gray-600 focus:border-blue-500" />
            
            <button @onclick="SendMessage" 
                    class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-600 text-white shadow-lg shadow-blue-600/20 transition-all hover:bg-blue-500 active:scale-95">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>
</div>

@code {
    private string userMessage = "Hello from Android!";
    private List<string> chatLog = new();

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }
    
    protected override async Task OnInitializedAsync()
    {
        TcpService.OnMessageReceived += HandleIncomingMessage;
        
        if (State.IsPaired)
        {
            chatLog.Add("System: Connecting to PC...");
            bool success = await TcpService.StayConnected(State.IpAddress, State.Port);
            
            if (success)
            {
                chatLog.Add("System: Connected! Ready to scan/chat.");
                await TcpService.SendLiveMessage($"AUTH_TOKEN:{State.Token}");
            }
            else
            {
                chatLog.Add("System: Connection failed. Is the PC app running?");
            }
        }
    }

    private void HandleIncomingMessage(string message)
    {
        InvokeAsync(() => 
        {
            chatLog.Add(message);
            StateHasChanged();
        });
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userMessage)) return;
        await TcpService.SendLiveMessage(userMessage);
        
        chatLog.Add($"You: {userMessage}");
        userMessage = "";
    }

    public void Dispose() => TcpService.OnMessageReceived -= HandleIncomingMessage;
}