    private async Task ConfirmItemVoid()
    {
        if (_parentSale == null || _itemToVoid == null) return;
        if (_quantityToRemove < 1)
        {
            _quantityToRemove = 1;
            Alert.Error("Quantity must be at least 1.");
            return;
        }

        if (_quantityToRemove > _itemToVoid.Quantity)
        {
            Alert.Error($"Cannot remove more than the purchased quantity ({_itemToVoid.Quantity}).");
            return;
        }
        var result = await saleService.VoidSingleItemAsync(_parentSale.Id, _itemToVoid, _quantityToRemove);

        if (result)
        {

            if (_parentSale.Items.Count <= 1 && _quantityToRemove == _itemToVoid.Quantity)
            {
                await saleService.VoidTransactionAsync(_parentSale, "All items removed", true);
            }

            // Refresh the list

            _isItemVoidModalVisible = false;
            Alert.Success($"Successfully returned {_quantityToRemove} pcs of {_itemToVoid.ProductName}."); await productService.LoadProductsAsync();
            await LoadSalesData();
            StateHasChanged();
        }
        else
        {
            Alert.Error("Failed to remove item.");
        }
    }
    private async Task ConfirmVoid()
    {
        if (_saleToVoid == null) return;
        if (string.IsNullOrWhiteSpace(_voidReason))
        {
            Alert.Warning("Please provide a reason for cancellation.");
            return;
        }

        _saleToVoid.IsVoided = true;
        _saleToVoid.VoidReason = _voidReason;
        _saleToVoid.VoidDate = DateTime.Now;
        _saleToVoid.VoidedBy = "Admin";

        bool success = await saleService.VoidTransactionAsync(_saleToVoid, _voidReason, true);

        if (success)
        {
            _isVoidConfirmVisible = false;
            await LoadSalesData();
            await productService.LoadProductsAsync();

            StateHasChanged();
            Alert.Success($"Invoice {_saleToVoid.InvoiceNumber} has been voided.");
        }
    }
