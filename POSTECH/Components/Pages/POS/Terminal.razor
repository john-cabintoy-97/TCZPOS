    private async Task ConfirmPayment()
    {
        // 1. Validation Logic
        if (_selectedPaymentType == "Credit")
        {
            if (_selectedCreditCustomer == null)
            {
                Alert.Warning("Please select a customer for credit transactions.");
                return;
            }

            decimal currentDebt = await CreditService.GetTotalCustomerDebtAsync(_selectedCreditCustomer.Id);
            decimal newTotalDebt = currentDebt + (NetTotal - _amountTendered);
        
            if (newTotalDebt > _selectedCreditCustomer.CreditLimit)
            {
                Alert.Warning($"Transaction Denied! This pushes the customer over their ₱{_selectedCreditCustomer.CreditLimit:N2} limit.");
                return;
            }
        }
        else if (ChangeDue < 0)
        {
            Alert.Warning("Insufficient amount tendered!");
            return;
        }


        // 2. Prepare the Sale Model
        var newSale = new SaleModels
        {
            InvoiceNumber = transactionNo,
            TotalAmount = SubTotal,
            TaxAmount = VatAmount,
            DiscountAmount = TotalDiscount,
            PaymentType = _selectedPaymentType,
        
            AmountPaid = _amountTendered,
        
            // Calculate remaining debt for credit sales
            CreditBalance = _selectedPaymentType == "Credit" ? (NetTotal - _amountTendered) : 0,
            PaymentStatus = _selectedPaymentType == "Credit" ? "Credit" : "Paid",
        
            CustomerId = _selectedCreditCustomer?.Id,
            CustomerName = _selectedCreditCustomer?.Name ?? "Walk-in",
        
            CashierName = Gatekeeper.ActiveStaff?.Name ?? "Unknown",
            TransactionDate = DateTime.Now
        };

        bool success = await saleService.ProcessFinalSaleAsync(newSale, CartItems);

        if (success)
        {
            await CompleteTransactionState();
        }
        else
        {
            Alert.Warning("Database Error: Could not save transaction.");
        }
    }

    private async Task CompleteTransactionState()
    {
        _isSettleModalVisible = false;
        _isCustomerPickerVisible = false;
    
        // Clear Cart & Transaction state
        await cartService.ClearAsync();
        isTransactionActive = false;
        transactionNo = "---";
    
        // Reset Selection
        _selectedCreditCustomer = null;
        _amountTendered = 0;
        _selectedPaymentType = "Cash";

        Alert.Success("Transaction Completed!");
    
        // Refresh Data
        await productService.LoadProductsAsync();
        await LoadCartData();
        await _mainContainer.FocusAsync();
        StateHasChanged();
    }
