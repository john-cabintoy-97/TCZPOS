    // Logic to Resume
    private async Task ResumeHeldOrder(HeldTransactionModel held)
    {
        if (!isTransactionActive || string.IsNullOrEmpty(transactionNo))
        {
            await StartNewTransaction();
        }

        if (CartItems != null && CartItems.Any())
        {
            Alert.Warning("Please clear your current cart before resuming an order.");
            return;
        }

        foreach (var heldItem in held.Items)
        {
            var cartItem = new CartModels
            {
                ProductId = heldItem.ProductId,
                TransactionNo = transactionNo,
                ProductName = heldItem.ProductName,
                Barcode = heldItem.Barcode,
                Pcode = heldItem.Pcode,
                UnitPrice = heldItem.UnitPrice,
                Quantity = heldItem.Quantity,
                DiscountValue = 0,
                DiscountType = "Percent"
            };

            await cartService.AddItemAsync(cartItem);
        }

        await heldService.RemoveHeldAsync(held.Id);

        _isHeldListVisible = false;
        HeldOrdersList = await heldService.GetAllHeldAsync();

        // 5. Very Important: Manually load the cart data to refresh the screen
        await LoadCartData();

        StateHasChanged();
        Alert.Success($"Transaction '{held.ReferenceName}' resumed.");
    }
