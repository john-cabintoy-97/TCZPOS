    // --- [ 8. INPUT & KEYBOARD HANDLERS ] ---
    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        var products = FilteredProducts.ToList();
        if (!products.Any()) return;

        if (e.Key == "ArrowDown")
        {
            if (_selectedProductIndex < products.Count - 1)
                _selectedProductIndex++;
        }
        else if (e.Key == "ArrowUp")
        {
            if (_selectedProductIndex > 0)
                _selectedProductIndex--;
        }
        else if (e.Key == "Enter")
        {
            var selectedProduct = products[_selectedProductIndex];
            await AddToCartFromSearch(selectedProduct);
        
            // _isSearchModalVisible = false;
        }
    }
    private async Task HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        if (_isSearchModalVisible || _isSettleModalVisible)
        {
            if (e.Key == "Escape") await CloseAllModals();
            return;
        }

        switch (e.Key)
        {
            case "F1": await StartNewTransaction(); break;
            case "F2": await OpenProductSearch(); break;
            case "F3": if (isTransactionActive && CartItems.Count > 0) await OpenDiscountModal(); break;
            case "F4": if (isTransactionActive && CartItems.Count > 0) OpenSettleModal(); break;
            case "F5": await cartService.ClearAsync(); break;
            case "F6": await OpenSalesModal(); break;
            case "F8": await FocusScanner(); break;
            case "Escape": await CloseAllModals(); break;
        }
    }
    private async Task HandleSettleKeyUp(KeyboardEventArgs e)
