@page "/pos/terminal"
@using System.Text.RegularExpressions;
@inject AlertServices Alert
@inject NavigationManager Nav
@using TCZPOS.Components.Modules
@using TCZPOS.Components.Modules.UX
@using TCZPOS.Components.Pages.POS.Components
@inject CartServices cartService;
@inject ProductServices productService;
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthStateProvider CustomAuthStateProvider
@inject HeldTransactionService heldService;
@implements IDisposable
@layout EmptyLayout
@inject IJSRuntime JSRuntime
@inject SaleServices saleService
@inject CustomerCreditService CreditService
@using CurrieTechnologies.Razor.Vibration;
@inject HardwareServices hardwareServices;
@using TCZPOS.Components.Guard.Interface
@inject CustomerService customerService;
@inject IGatekeeperService Gatekeeper


<div @onclick="(() => _mainContainer.FocusAsync())" @ref="_mainContainer" class="flex h-screen w-full flex-col font-sans text-white overflow-hidden" tabindex="0" focus:outline-none"
     @onkeydown="HandleGlobalKeyDown">
    <POSHeader CashierName="@(Gatekeeper.ActiveStaff?.Name ?? "Unknown")"
               TerminalName="Terminal 01"
               TransactionNo="@transactionNo"
               TransactionDate="@transactionDate"
               NetTotal="@NetTotal"
               VatAmount="@VatAmount" />

    <div class="flex flex-1 flex-col overflow-hidden lg:flex-row">
        @* MAIN CONTENT AREA *@
        <div class="flex flex-1 flex-col overflow-hidden bg-white text-slate-800">
            @* BARCODE & INFO *@
            <div class="grid grid-cols-1 gap-4 border-b bg-slate-50 p-4 md:grid-cols-2">
                <div class="space-y-1">
                    <p class="text-[10px] font-bold text-slate-400 uppercase">
                        Transaction No: <span class="ml-2 font-mono text-red-500">@transactionNo</span>
                    </p>
                    <p class="text-[10px] font-bold text-slate-400 uppercase">
                        Date: <span class="ml-2 text-slate-800">@transactionDate</span>
                    </p>
                </div>
    
                <POSActions @ref="_barcodeScanner"
                            IsActive="@isTransactionActive"
                            @bind-Value="_barcodeInput"
                            OnFocus="@RefocusAsync"
                            OnSubmit="HandleBarcodeKeyUp" />

            </div>

        
            @* TABLE AREA *@
            <div class="flex flex-1 flex-col overflow-hidden bg-white">
                <GenericTable TItem="CartModels"
                              TableTitle="Current Transaction"
                              IsLoading="isLoading"
                              ShowSelection="false"
                              Items="CartItems"
                              OnRowClick="SelectItem"
                              RowClassFunc='(item) => _selectedRowItem?.Id == item.Id ? "bg-orange-50 border-l-4 border-orange-500 shadow-inner" : "hover:bg-slate-100"'
                              TotalCount="CartItems.Count"
                              PageSize="10">
                    <TableHeader>
                        <th class="md:hidden px-4 py-3 text-left text-xs uppercase tracking-wider">
                            Transaction Items
                        </th>
                        <th class="hidden md:table-cell w-12 px-4 py-3 text-center">#</th>
                        <th class="hidden md:table-cell px-4 py-3">Product Details</th>
                        
                        <th class="hidden md:table-cell px-4 py-3">Barcode/Code</th>
                        <th class="hidden md:table-cell w-32 px-4 py-3 text-right">Rate</th>
                        <th class="hidden md:table-cell w-40 px-4 py-3 text-center">Qty</th>
                        <th class="hidden md:table-cell w-32 px-4 py-3 text-right">Total</th>
                        <th class="hidden md:table-cell w-20 px-4 py-3 text-center">Action</th>
                    </TableHeader>
                    <RowTemplate Context="row">
                        @* --- MOBILE VIEW (Same as before with separation line) --- *@
                        <td colspan="7" class="md:hidden p-0 border-b-4 border-slate-200 bg-white hover:bg-slate-50 transition-colors">
                            <div class="flex flex-col gap-3 p-4">
                                @* Qty Control *@
                                <div class="flex items-center justify-between bg-white p-2 rounded-lg border border-slate-200 shadow-sm">
                                    <span class="text-[10px] font-bold text-slate-400 uppercase">Quantity</span>
                                    <div class="flex items-center border border-slate-300 rounded-lg overflow-hidden bg-white">
                                        <button @onclick="() => DecreaseQty(row.Item)" class="px-4 py-1 bg-slate-50 text-slate-600 active:bg-slate-200">-</button>
                                        <input type="number"
                                               value="@row.Item.Quantity"
                                               readonly
                                               min="1"
                                               max="@(productService.ProductDisplayList.FirstOrDefault(p => p.Product.Barcode == row.Item.Barcode)?.Product.StockLevel ?? 999)"
                                               class="w-12 text-center font-mono text-xs font-bold border-none outline-none focus:ring-0" />
                                        <button @onclick="() => IncreaseQty(row.Item)" class="px-4 py-1 bg-slate-50 text-slate-600 active:bg-slate-200">+</button>
                                    </div>
                                </div>

                                @* Product Details *@
                                <div class="flex justify-between items-start">
                                    <div class="flex flex-col">
                                        <span class="font-black text-slate-800 uppercase text-sm">@row.Item.ProductName</span>
                                        @if (row.Item.ItemDiscountAmount > 0)
                                        {
                                            <div class="flex items-center gap-1 mt-1 mb-1">
                                                <span class="w-fit text-[8px] bg-red-600 text-white px-1.5 py-0.5 rounded-sm font-black uppercase shadow-sm">
                                                    SAVE ₱@row.Item.ItemDiscountAmount.ToString("N2")
                                                </span>
                                                @if (row.Item.DiscountType == "Percent")
                                                {
                                                    <span class="text-[9px] text-slate-400 font-bold">(@row.Item.DiscountValue%)</span>
                                                }
                                            </div>
                                        }
                                        <span class="text-[9px] text-slate-400 font-mono">BC: @row.Item.Barcode | PC: @row.Item.Pcode</span>
                                    </div>
                                    <div class="text-right">
                                        <div class="text-[9px] text-slate-400 uppercase font-black">Sub-Total</div>
                                        <div class="font-mono text-lg font-black text-orange-600">₱ @row.Item.SubTotal.ToString("N2")</div>
                                    </div>
                                </div>

                                @* Action Bar *@
                                <div class="flex justify-between items-center pt-3 border-t border-slate-100">
                                    <span class="text-xs text-slate-500 font-mono">Rate: ₱ @row.Item.UnitPrice.ToString("N2")</span>
                                    <button @onclick="() => RemoveItem(row.Item.Id)"
                                            class="flex items-center gap-2 bg-red-50 text-red-500 px-3 py-1.5 rounded-md font-bold text-[10px] uppercase">
                                        <i class="fas fa-trash-alt"></i> Remove
                                    </button>
                                </div>
                            </div>
                        </td>

                        @* --- DESKTOP VIEW WITH HOVER --- *@
                        <td class="hidden md:table-cell px-4 py-4 text-center text-slate-400 font-mono text-[10px] border-b border-slate-100 transition-colors">
                            @row.Index
                        </td>
    
                        <td class="hidden md:table-cell px-4 py-4 border-b border-slate-100 transition-colors">
                            <div class="flex flex-col">
                                <span class="font-bold text-slate-800 uppercase leading-tight group-hover:text-orange-600 transition-colors">@row.Item.ProductName</span>
                                @if (row.Item.ItemDiscountAmount > 0)
                                {
                                    <div class="flex items-center gap-1 mt-1">
                                        <span class="w-fit text-[9px] bg-red-600 text-white px-1.5 py-0.5 rounded-sm font-black uppercase">
                                            SAVE ₱@row.Item.ItemDiscountAmount.ToString("N2")
                                        </span>
                                        @if (row.Item.DiscountType == "Percent")
                                        {
                                            <span class="text-[9px] text-slate-400 font-bold">(@row.Item.DiscountValue%)</span>
                                        }
                                    </div>
                                }
                            </div>
                        </td>

                        <td class="hidden md:table-cell px-4 py-4 border-b border-slate-100 transition-colors">
                            <div class="flex flex-col gap-0.5 opacity-80">
                                <span class="font-mono text-[11px] text-slate-700">BC: @row.Item.Barcode</span>
                                <span class="font-mono text-[10px] text-slate-400 uppercase">PC: @row.Item.Pcode</span>
                            </div>
                        </td>

                        <td class="hidden md:table-cell px-4 py-4 text-right font-mono text-xs text-slate-600 border-b border-slate-100 transition-colors">
                            ₱ @row.Item.UnitPrice.ToString("N2")
                        </td>
                        <td class="hidden md:table-cell px-4 py-4 text-center border-b border-slate-100 transition-colors">
                            <div class="flex items-center justify-center">
                                <div @onclick:stopPropagation="true"
                                     class="flex items-center border border-slate-200 rounded-lg overflow-hidden bg-white shadow-sm hover:border-orange-400 transition-all">
            
                                    <button @onclick="() => DecreaseQty(row.Item)"
                                            class="px-2 py-1 bg-slate-50 hover:bg-orange-50 text-slate-600 active:bg-orange-100 transition-colors">
                                        -
                                    </button>
            
                                    <input type="number"
                                           @bind="row.Item.Quantity"
                                           @bind:event="oninput"
                                           @onchange="@(async (e) => await ManualUpdateQty(row.Item, row.Item.Quantity.ToString()))"
                                           min="1"
                                           max="@(productService.ProductDisplayList.FirstOrDefault(p => p.Product.Barcode == row.Item.Barcode)?.Product.StockLevel ?? 999)"
                                           onkeypress="return (event.charCode != 8 && event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57))"
                                           class="w-12 text-center font-mono text-xs font-bold text-slate-800 border-none outline-none focus:ring-0" />
            
                                    <button @onclick="() => IncreaseQty(row.Item)"
                                            class="px-2 py-1 bg-slate-50 hover:bg-orange-50 text-slate-600 active:bg-orange-100 transition-colors">
                                        +
                                    </button>
                                </div>
                            </div>
                        </td>
                        <td class="hidden md:table-cell px-4 py-4 text-right border-b border-slate-100 transition-colors">
                            <span class="font-mono text-sm font-black text-slate-900">₱ @row.Item.SubTotal.ToString("N2")</span>
                        </td>

                        <td class="hidden md:table-cell px-4 py-4 text-center border-b border-slate-100 transition-colors">
                            <button @onclick="() => RemoveItem(row.Item.Id)"
                                    class="text-slate-300 hover:text-red-600 hover:scale-110 transition-all p-2">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </td>
                      
                    </RowTemplate>
                </GenericTable>
            </div>

            @* UPDATED TOTALS FOOTER *@
            <POSTotals SubTotal="SubTotal" VatAmount="VatAmount" NetTotal="NetTotal" />
        </div>

        @* DESKTOP SIDEBAR (Visible only on LG screens) *@
        <POSSidebar IsTransactionActive="isTransactionActive"
                    HasItems="@(CartItems.Count > 0)"
                    OnNewTransaction="StartNewTransaction"
                    OnSearch="OpenProductSearch"
                    OnDiscount="OpenDiscountModal"
                    IsItemSelected="@(_selectedRowItem != null)"
                    OnSettle="OpenSettleModal"
                    OnSales="OpenSalesModal"
                    OnHold="OpenHoldModal"
                    HeldOrdersCount="@HeldOrdersCount"
                    OnClear="() => cartService.ClearAsync()"
                    OnExit="HandleExit" />
    </div>

    @* MOBILE BOTTOM NAVIGATION *@
    <POSMobileNav IsTransactionActive="@isTransactionActive"
                  HasItems="@(CartItems.Count > 0)"
                  IsItemSelected="@(_selectedRowItem != null)"
                  OnNewTransaction="StartNewTransaction"
                  OnSearch="OpenProductSearch"
                  OnSales="OpenSalesModal"
                  OnHold="OpenHoldModal"
                  HeldOrdersCount="@HeldOrdersCount"
                  OnDiscount="OpenDiscountModal"
                  OnSettle="OpenSettleModal"
                  OnExit="HandleExit" />
</div>

@if (_isSearchModalVisible)
{
    <Modal IsVisible="_isSearchModalVisible"
           Title="Select Product"
           ShowFooter="false"
           customCss="!rounded-br-[15px] !rounded-bl-[15px]"
           OnClose="() => _isSearchModalVisible = false">
        <ChildContent>
            <div class="mb-0 p-3 ">
                <div class="flex flex-1  overflow-hidden rounded-xl border border-slate-300 bg-white shadow-sm focus-within:border-orange-500 focus-within:ring-1 focus-within:ring-orange-500/20">
                    <input type="text" @bind="ProductSearchTerm" @bind:event="oninput"
                           @onkeydown="HandleSearchKeyDown"
                           class="w-full text-slate-800 px-4 py-2 text-sm font-medium outline-none"
                           placeholder="Search description or barcode..." />
                    <div class="flex items-center bg-slate-50 px-3 border-l border-slate-200 text-slate-400">
                        <i class="fas fa-search text-xs"></i>
                    </div>
                </div>
            </div>
            <div class="h-[50vh]">
                <GenericTable TItem="ProductModels"
                              Items="FilteredProducts"
                              ShowSelection="false"
                              customCss="rounded-br-[15px] rounded-bl-[15px]"
                              TableTitle="Product List"
                              TotalCount="FilteredProducts.Count()"
                              PageSize="5">
                    <TableHeader>
                        <th class=" px-4 py-3 text-left text-xs uppercase tracking-wider">
                            Products List
                        </th>
                    </TableHeader>
                    <RowTemplate Context="row">
                        @{
                            // Unified the variable name to 'inCart'
                            var inCart = CartItems.FirstOrDefault(x => x.ProductId == row.Item.Id)?.Quantity ?? 0;
                            var isExhausted = row.Item.StockLevel <= inCart;
                            var remainingStock = row.Item.StockLevel - inCart;
                        }

                        <td colspan="7" class=" p-0 border-b-4 border-slate-200 bg-white hover:bg-slate-50 transition-colors">
                            <div class="flex flex-col gap-3 p-4">
                                @* Qty Control *@
                                <div class="flex items-center justify-between bg-white p-2 rounded-lg border border-slate-200 shadow-sm">
                                    <span class="text-[10px] font-bold text-slate-400 uppercase">Quantity</span>
                                    <div class="flex items-center border border-slate-300 rounded-lg overflow-hidden bg-white">
                                        <input type="number"
                                               min="1"
                                               max="@remainingStock"
                                               disabled="@isExhausted"
                                               @bind="row.Item.TempQty"
                                               class="w-16 rounded border border-slate-300 bg-white px-2 py-1 text-center text-xs font-bold text-slate-800 outline-none focus:border-orange-500 @(isExhausted ? "opacity-50 bg-gray-100" : "")" />

                                    </div>
                                </div>

                                @* Product Details *@
                                <div class="flex justify-between items-start">
                                    <div class="flex flex-col">
                                        <span class="font-black text-slate-800 uppercase text-sm">@row.Item.Name</span>
                                        <span class="text-[9px] text-slate-400 font-mono">BC: @row.Item.Barcode | PC: @row.Item.Pcode</span>
                                    </div>
                                    <div class="text-right">
                                        <div class="text-[9px] text-slate-400 uppercase font-black">Total Stock</div>
                                        <span class="font-mono text-xs @row.Item.StockStatusColor">@row.Item.StockLevel @row.Item.Unit</span>
                                        @if (inCart > 0)
                                        {
                                            <div class="text-[9px] font-mono text-lg font-black text-orange-600">
                                                (@inCart in cart)
                                            </div>
                                        }
                                       
                                    </div>
                                </div>

                                @* Action Bar *@
                                <div class="flex justify-between items-center pt-3 border-t border-slate-100">
                                    <span class="text-xs text-slate-500 font-mono">Price:  ₱ @row.Item.SellingPrice.ToString("N2")</span>
                                    <button type="button"
                                            @onclick="() => AddToCartFromSearch(row.Item)"
                                            disabled="@isExhausted"
                                            class="rounded-lg px-4 py-1.5 text-[10px] font-black text-white transition-all
                                        @(isExhausted ? "bg-gray-400 cursor-not-allowed" : "bg-orange-500 hover:bg-orange-600 active:scale-95")">
                                        @(isExhausted ? "MAXED" : "SELECT")
                                    </button>
                                    
                                </div>
                            </div>
                        </td>
                    </RowTemplate>
                </GenericTable>
            </div>
        </ChildContent>
    </Modal>
}

@if (_isSettleModalVisible)
{
    <Modal IsVisible="_isSettleModalVisible"
           DisableBackdropClick="true"
           CustomFooterCss="px-6 py-4"
           Title="Settle Payment"
           OnClose="() => _isSettleModalVisible = false">
        <ChildContent>
            <div class="flex flex-col gap-4 p-6 bg-[#1E2939]">
                <div class="rounded-xl bg-slate-900 p-4 text-right">
                    <p class="text-[10px] font-bold uppercase text-slate-400">Total Amount Due</p>
                    <p class="font-mono text-3xl font-black text-[#a3ff00]">₱ @NetTotal.ToString("N2")</p>
                </div>

                <div class="space-y-1">
                    <label class="text-[10px] font-bold uppercase text-slate-500">Amount Tendered</label>
                    <input @onkeyup="HandleSettleKeyUp" type="number" @bind="_amountTendered" @bind:event="oninput"
                           class="w-full rounded-lg border-2 border-slate-200 bg-white p-3 text-right font-mono text-2xl font-bold text-slate-800 outline-none focus:border-orange-500"
                           placeholder="0.00" />
                </div>
                <div class="space-y-2">
                    <label class="text-[10px] font-bold uppercase text-slate-500">Payment Method</label>
                    <div class="grid grid-cols-3 gap-2">
                        @foreach (var method in new[] { "Cash", "GCash", "Credit" })
                        {
                            <button @onclick="() => SetPaymentMethod(method)"
                                    class="@(_selectedPaymentType == method
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        ? "bg-orange-500 border-orange-500 text-white shadow-md"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        : "bg-slate-800 border-slate-700 text-slate-400")
                                flex flex-col items-center justify-center py-3 rounded-xl border-2 transition-all active:scale-95">
                                <i class="@(method == "Cash" ? "fas fa-money-bill-wave" : method == "GCash" ? "fas fa-mobile-alt" : "fas fa-hand-holding-usd") mb-1"></i>
                                <span class="text-[10px] font-black uppercase">@method</span>
                            </button>
                        }
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-2">
                    @foreach (var cash in new decimal[] { 50, 100, 200, 500, 1000 })
                    {
                        <button @onclick="() => QuickCash(cash)"
                                class="rounded-lg border border-slate-200 bg-slate-500 text-white py-2 text-xs font-bold hover:bg-slate-100 transition-all">
                            +₱ @cash
                        </button>
                    }
                    <button @onclick="() => _amountTendered = 0" class="rounded-lg bg-red-50 text-red-600 py-2 text-xs font-bold hover:bg-red-100">
                        CLEAR
                    </button>
                </div>

                @* Change Due Display *@
                <div class="flex items-center justify-between border-t border-dashed border-slate-300 pt-4">
                    <span class="text-sm font-bold text-white uppercase">Change Due</span>
                    <span class="font-mono text-2xl text-white @(ChangeDue < 0 ? "text-red-500" : "text-slate-900")">
                        ₱ @(ChangeDue < 0 ? "0.00" : ChangeDue.ToString("N2"))
                    </span>
                </div>

               
            </div>
        </ChildContent>
        <CustomFooter>
            @if (_selectedPaymentType == "Credit")
            {
                <div class="w-full flex flex-col gap-2">
                    @if (_selectedCreditCustomer != null)
                    {
                        <div class="flex items-center justify-between px-4 py-2 bg-slate-800 rounded-lg border border-orange-500/30">
                            <span class="text-[10px] text-slate-400 uppercase font-bold">Debtor:</span>
                            <span class="text-xs text-orange-400 font-black uppercase">@_selectedCreditCustomer.Name</span>
                        </div>
                    }
                    <button disabled="@(_selectedCreditCustomer == null)"
                            @onclick="ConfirmPayment"
                            class="mt-2 w-full rounded-2xl bg-blue-600 py-4 text-sm font-black uppercase text-white shadow-lg transition-all hover:bg-blue-700 active:scale-95 disabled:opacity-50">
                        <i class="fas fa-file-invoice-dollar mr-2"></i> Confirm Credit Sale
                    </button>
                </div>
            }
            else
            {
                <button disabled="@(ChangeDue < 0 || NetTotal <= 0)"
                        @onclick="ConfirmPayment"
                        class="mt-2 w-full rounded-2xl bg-orange-500 py-4 text-sm font-black uppercase text-white shadow-lg shadow-orange-500/30 transition-all hover:bg-orange-600 active:scale-95 disabled:grayscale">
                    <i class="fas fa-check-circle mr-2"></i> Confirm Payment
                </button>
            }
        </CustomFooter>
    </Modal>
}

@if (_isCustomerPickerVisible)
{
    <Modal IsVisible="_isCustomerPickerVisible"
           Title="Credit Customer Selection"
           ShowFooter="false"
           customCss="!rounded-br-[15px] !rounded-bl-[15px]"
           OnClose="() => _isCustomerPickerVisible = false">
        <ChildContent>
            <div class="flex flex-col gap-4 p-4 ">
                @* Search/List Section *@
                <div class="space-y-2">
                    <label class="text-[10px] font-bold uppercase text-slate-500">Search Existing Debtor</label>
                    
                    <ComboBox TItem="CustomerModels"
                              BgClass="!p-1 !bg-white p-3 text-slate-800"
                              BorderClass="border-slate-700"
                              IconClass="fas fa-users"
                              TValue="int?"
                              Value="_selectedCreditCustomer?.Id"
                              ValueChanged="HandleCustomerSelected"
                              Items="customerService.CustomerList"
                              ValueSelector="@(c => (int?)c.Id)"
                              SearchSelector="@(c => c.Name)"
                             >
                        <ItemTemplate>
                            <div class="flex justify-between items-center w-full">
                                <span class="font-bold">@context.Name</span>
                                <span class="text-[9px] opacity-50 font-mono">Limit: ₱@context.CreditLimit.ToString("N2")</span>
                            </div>
                        </ItemTemplate>
                    </ComboBox>
                </div>

                @if (_selectedCreditCustomer != null)
                {
                    @* Show this if an existing customer is picked from the ComboBox *@
                    <div class="mt-4 p-4 rounded-xl border border-orange-500/30 bg-orange-500/10 animate-in fade-in zoom-in duration-200">
                        <div class="flex items-center justify-between mb-3">
                            <div>
                                <p class="text-[10px] text-orange-500 uppercase font-black">Selected Debtor</p>
                                <p class="text-slate-500 font-bold">@_selectedCreditCustomer.Name</p>
                            </div>
                            <button @onclick="() => _selectedCreditCustomer = null" class="text-slate-500 hover:text-red-500">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
        
                        <button @onclick="ConfirmSelection"
                                class="w-full bg-green-600 hover:bg-green-700 text-white py-3 rounded-lg text-xs font-black uppercase transition-all shadow-lg shadow-green-900/20">
                            Proceed with @(_selectedCreditCustomer.Name.Split(' ')[0])
                        </button>
                    </div>
                }
                else
                {
                    @* Show the Register Section only if no one is selected yet *@
                    <div class="relative">
                        <div class="absolute inset-0 flex items-center"><span class="w-full border-t border-slate-800"></span></div>
                        <div class="relative flex justify-center text-[10px] uppercase font-black">
                            <span class="text-slate-600">OR REGISTER NEW</span>
                        </div>
                    </div>

                    <div class="space-y-3 bg-[#1E2939] p-4 rounded-xl border border-slate-800">
                        <input type="text" @bind="_newCustomerName" placeholder="Full Name"
                               class="w-full text-slate-800 bg-white border border-slate-700 rounded-lg p-2 text-sm " />
                        <input type="text" @bind="_newCustomerPhone" placeholder="Phone Number"
                               class="w-full text-slate-800 bg-white border border-slate-700 rounded-lg p-2 text-sm " />

                        <button @onclick="RegisterAndSelectCustomer"
                                disabled="@string.IsNullOrWhiteSpace(_newCustomerName)"
                                class="w-full bg-orange-600 hover:bg-orange-700 text-white py-2 rounded-lg text-xs font-black uppercase transition-all disabled:opacity-50">
                            Register & Use
                        </button>
                    </div>
                }
            </div>
        </ChildContent>
    </Modal>
}

@if (_isDiscountModalVisible)
{

    <Modal IsVisible="_isDiscountModalVisible"
           Title="Apply Discount"
           OnClose="() => _isDiscountModalVisible = false">
        <ChildContent>
            <div class="flex flex-col gap-6 p-6">
                <div class="flex rounded-xl bg-slate-100 p-1.5 shadow-inner">
                    <button type="button"
                            @onclick='() => _discountType = "Percent"'
                            class="flex-1 py-3 rounded-lg text-xs font-black uppercase transition-all duration-200
                        @(_discountType == "Percent" ? "bg-orange-500 text-white shadow-md ring-1 ring-orange-400" : "text-slate-400 hover:text-slate-600")">
                        Percent (%)
                    </button>
        
                    <button type="button"
                            @onclick='() => _discountType = "Fixed"'
                            class="flex-1 py-3 rounded-lg text-xs font-black uppercase transition-all duration-200
                        @(_discountType == "Fixed" ? "bg-orange-50 text-orange-600 shadow-md ring-1 ring-orange-200" : "text-slate-400 hover:text-slate-600")">
                        Fixed (₱)
                    </button>
                </div>

                @* INPUT FIELD - Focused Design *@
                <div class="space-y-2">
                    <div class="flex justify-between items-end">
                        <label class="text-[10px] font-black uppercase tracking-widest text-slate-400">Discount Value</label>
                        <span class="text-[10px] font-mono text-slate-300">@(_discountType == "Percent" ? "%" : "PHP")</span>
                    </div>
                    <div class="relative">
                        <div class="space-y-2">
                            <input type="number" min="0" @bind="_discountValueString" @bind:event="oninput"
                                   class="w-full rounded-lg border-2 border-slate-200 bg-white p-2 text-right font-mono text-2xl font-bold text-slate-800 outline-none focus:border-orange-500"
                                   placeholder="0.00" />
                            <span class="text-[10px] font-mono text-slate-300">@(_discountType == "Percent" ? "Enter percentage (0-100)" : "Enter fixed amount in PHP")</span>
                        </div>
                    </div>
                </div>

                @* DEDUCTION PREVIEW - Redesigned for clarity *@
                <div class="relative overflow-hidden rounded-2xl bg-slate-600 p-6 text-center border-2 border-dashed border-red-100">
                    <p class="text-[10px] font-black uppercase tracking-tighter text-white mb-1">Estimated Deduction</p>
                    <div class="flex items-center justify-center gap-2">
                        <span class="text-yellow-700 font-black text-2xl">-</span>
                        <span class="font-mono text-4xl font-black text-yellow-600">₱ @CalculateDiscountAmount().ToString("N2")</span>
                    </div>
                </div>
            </div>
        </ChildContent>

        <CustomFooter>
            <div class="p-2 w-full">
                <Button Variant="ButtonVariant.Sidebar"
                        Icon="fas fa-check-circle"
                        Label="Apply Discount"
                        IsEnabled="@(_discountValue > 0)"
                        OnClick="ApplyDiscount"
                        class="w-full bg-orange-500 border-none9+6 rounded-2xl shadow-xl shadow-slate-900/30 text-lg uppercase tracking-widest hover:bg-black transition-all active:scale-[0.98]" />
            </div>
        </CustomFooter>
    </Modal>
}

@if (_isSalesModalVisible)
{
    <Modal IsVisible="_isSalesModalVisible"
           Title="Daily Sales"
           ShowFooter="false"
           customCss="rounded-br-[15px] rounded-bl-[15px]"
           OnClose="() => _isSalesModalVisible = false">
        <ChildContent>
            <div class="p-4  space-y-3 shadow-md border-b border-slate-100">
                <div class="flex flex-col sm:flex-row gap-3">
        
                    <div class="flex flex-1 max-w-md overflow-hidden rounded-xl border border-slate-300 bg-white shadow-sm focus-within:border-orange-500 focus-within:ring-1 focus-within:ring-orange-500/20">
                        <input type="text" @bind="_salesSearchQuery" @bind:event="oninput"
                               class="w-full text-slate-800 px-4 py-2 text-sm font-medium outline-none"
                               placeholder="Serch Invoice and Time..." />
                        <div class="flex items-center bg-slate-50 px-3 border-l border-slate-200 text-slate-400">
                            <i class="fas fa-search text-xs"></i>
                        </div>
                    </div>
                    <div class="flex flex-1 max-w-md overflow-hidden rounded-xl border border-slate-300 bg-white shadow-sm focus-within:border-orange-500 focus-within:ring-1 focus-within:ring-orange-500/20">
                        <input readonly type="date" @bind="_selectedSalesDate" @bind:after="LoadSalesData"
                               class="w-full text-slate-800 px-4 py-2 text-sm font-medium outline-none" />
                        <div class="flex items-center bg-slate-50 px-3 border-l border-slate-200 text-slate-400">
                            <i class="fas fa-calendar text-xs"></i>
                        </div>
                    </div>
                   
                </div>
            </div>
            <div class="h-[50vh] overflow-y-auto  ">
                <GenericTable TItem="SaleModels"
                              Items="FilteredSalesList"
                              TableTitle="Today's Transactions"
                              TotalCount="DailySalesList.Count"
                              customCss="rounded-br-[15px] rounded-bl-[15px]"
                              ShowSelection="false"
                              PageSize="10">
                    <TableHeader>
                        <th class=" px-4 py-3 text-left text-xs uppercase tracking-wider">
                            Today's Transactions
                        </th>
                    </TableHeader>
                    <RowTemplate Context="row">
                        <td class="p-0 border-b-4 border-slate-200 bg-white hover:bg-slate-50 transition-colors">
                            <div class="flex flex-col gap-3 p-4">
                                @* 1. Header: Invoice & Status *@
                                <div class="flex justify-between items-center">
                                    <div class="flex flex-col">
                                        <span class="font-black text-slate-800 uppercase text-sm">@row.Item.InvoiceNumber</span>
                                        <div class="flex items-center gap-2">
                                            @* Time Display *@
                                            <span class="text-[10px] text-slate-500 font-bold">
                                                <i class="far fa-clock mr-1"></i> @row.Item.TransactionDate.ToString("hh:mm tt")
                                            </span>

                                            @* Conditional Debtor Name *@
                                            @if (row.Item.IsCredit)
                                            {
                                                <span class="flex items-center gap-1 text-[10px] text-orange-600 font-black uppercase bg-orange-50 px-1.5 py-0.5 rounded border border-orange-100">
                                                    <i class="fas fa-user text-[8px]"></i> @row.Item.CustomerName
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    <div class="flex flex-col items-end gap-1">
                                        @if (row.Item.IsVoided)
                                        {
                                            <span class="px-2 py-1 rounded text-[10px] font-black bg-red-100 text-red-600">
                                                VOID
                                            </span>
                                        }
                                        else if (row.Item.IsCredit)
                                        {
                                            @* Show UTANG/CREDIT badge *@
                                            <div class="flex flex-col items-end">
                                                <span class="px-2 py-1 rounded text-[10px] font-black bg-orange-100 text-orange-600 uppercase">
                                                    CREDIT (UTANG)
                                                </span>
                                                @if (row.Item.CreditBalance > 0)
                                                {
                                                    <span class="text-[9px] font-bold text-orange-400">
                                                        Bal: ₱@row.Item.CreditBalance.ToString("N2")
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-1 rounded text-[10px] font-black bg-green-100 text-green-600">
                                                PAID
                                            </span>
                                        }

                                        @if (row.Item.IsVoided && !string.IsNullOrEmpty(row.Item.VoidReason))
                                        {
                                            <span class="text-[9px] text-red-400 italic">Reason: @row.Item.VoidReason</span>
                                        }
                                    </div>
                                </div>

                                @foreach (var detail in row.Item.Items)
                                {
                                    <div class="flex justify-between items-center text-[11px] py-1 border-b border-slate-50 last:border-0">
                                        <div class="flex items-center gap-2">
                       
                                            @if (!row.Item.IsVoided && row.Item.Items.Count > 1)
                                            {
                                                <button @onclick="() => SelectItemForVoid(row.Item, detail)"
                                                        @onclick:stopPropagation="true"
                                                        class="text-red-500 hover:text-red-700 p-1 transition-colors"
                                                        title="Remove Item">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            }
                                            else if (!row.Item.IsVoided && row.Item.Items.Count == 1)
                                            {
                                                @* Optional: Show a small info icon or just padding to keep alignment *@
                                                <div class="w-6"></div>
                                            }

                                            <span class="text-slate-600 font-medium">
                                                <span class="font-black text-slate-400">@detail.Quantity x</span> @detail.ProductName
                                            </span>
                                        </div>
                                        <span class="font-mono text-slate-500 font-bold">
                                            ₱@((detail.Quantity * (double)detail.UnitPrice).ToString("N2"))
                                        </span>
                                    </div>
                                }
                                @* 3. Transaction Summary & Actions *@
                                <div class="flex justify-between items-center bg-slate-50 p-2 rounded-lg mt-1">
                                    <div class="flex flex-col">
                                        <div class="text-[10px] font-bold text-slate-500 uppercase">Total Amount</div>
                                        <div class="font-black text-slate-800 text-sm">₱ @row.Item.TotalAmount.ToString("N2")</div>
                                        @if (row.Item.IsCredit && row.Item.AmountPaid > 0)
                                        {
                                            <div class="text-[9px] text-green-600 font-bold">
                                                <i class="fas fa-check-circle"></i> Paid: ₱ @row.Item.AmountPaid.ToString("N2")
                                            </div>
                                        }
                                    </div>
    
                                    @if (!row.Item.IsVoided)
                                    {
                                        <button @onclick="() => SelectSaleForVoid(row.Item)"
                                                class="px-4 py-2 bg-red-500 hover:bg-red-600 text-white text-[10px] font-black uppercase rounded shadow-sm transition-transform active:scale-95">
                                            Void Sale
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-[9px] font-black text-red-400 uppercase italic">Transaction Cancelled</span>
                                    }
                                </div>
                            </div>
                        </td>
                      
                    </RowTemplate>
                </GenericTable>
            </div>
        </ChildContent>
    </Modal>
}

@if (_isVoidConfirmVisible)
{
    <Modal IsVisible="_isVoidConfirmVisible"
           Title="Void Transaction"
           OnClose="() => _isVoidConfirmVisible = false">
        <ChildContent>
            <div class="p-6 space-y-4">
                @* 1. High-Level Danger Alert *@
                <div class="bg-red-50 p-3 rounded border border-red-100 flex items-start gap-3">
                    <i class="fas fa-exclamation-circle text-red-600 mt-1"></i>
                    <div>
                        <p class="text-xs text-red-600 font-black uppercase">Critical Action</p>
                        <p class="text-[11px] text-red-500">
                            You are about to void <b>@_saleToVoid?.InvoiceNumber</b>. This will cancel the entire transaction and restock all items.
                        </p>
                    </div>
                </div>
                
                @* 2. Reason Input *@
                <div class="space-y-1">
                    <label class="text-[10px] font-black text-slate-500 uppercase">Reason for Cancellation</label>
                    <textarea @bind="_voidReason"
                              class="w-full p-2 text-slate-800 border-2 border-slate-200 rounded text-sm bg-white focus:border-red-500 focus:ring-0 outline-none transition-colors"
                              placeholder="Required: e.g. Customer change mind, Wrong payment method..."></textarea>
                </div>

                @* 3. Items to be Restocked (NEW LIST SECTION) *@
