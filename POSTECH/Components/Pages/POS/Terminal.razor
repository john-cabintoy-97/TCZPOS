    private List<SaleModels> FilteredSalesList
    {
        get
        {
            var query = DailySalesList.AsEnumerable();
            var currentCashier = Gatekeeper.ActiveStaff?.Name;
            if (!string.IsNullOrEmpty(currentCashier))
            {
                query = query.Where(s => s.CashierName == currentCashier);
            }

            if (!string.IsNullOrWhiteSpace(_salesSearchQuery))
            {
                query = query.Where(s =>
                    s.InvoiceNumber.Contains(_salesSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    s.TransactionDate.ToString("hh:mm tt").Contains(_salesSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                    s.CustomerName.Contains(_salesSearchQuery, StringComparison.OrdinalIgnoreCase)
                );
            }

            return query.OrderByDescending(s => s.TransactionDate).ToList();
        }
    }

