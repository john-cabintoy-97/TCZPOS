                        @foreach (var item in CartItems)
                        {
                            <div class="flex justify-between items-center text-[11px] border-b border-slate-200 pb-2 last:border-0">
                                <div class="flex flex-col">
                                    <span class="font-bold text-slate-700">@item.ProductName</span>
                                    <span class="text-slate-500">Qty: @item.Quantity</span>
