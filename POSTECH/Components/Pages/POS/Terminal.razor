                    <label class="text-[10px] font-black text-slate-500 uppercase">Items to Restock</label>
                    <div class="max-h-[120px] overflow-y-auto rounded border border-slate-200 bg-slate-50">
                        @if (_saleToVoid?.Items != null)
                        {
                            @foreach (var item in _saleToVoid.Items)
                            {
                                <div class="flex justify-between items-center p-2 border-b border-slate-200 last:border-0 text-[11px]">
                                    <span class="text-slate-700">
                                        <span class="font-black text-slate-400">@item.Quantity x</span> @item.ProductName
                                    </span>
                                    <span class="font-mono text-slate-500">₱@((item.Quantity * (double)item.UnitPrice).ToString("N2"))</span>
                                </div>
                            }
                        }
                    </div>
                </div>

                @* 4. System Impact Summary *@
                <div class="bg-slate-800 p-3 rounded border border-slate-700">
                    <div class="flex justify-between items-center text-[10px]">
                        <span class="text-slate-400 font-bold uppercase">Total Refund Amount</span>
                        <span class="text-red-400 font-black font-mono text-xs">₱ @_saleToVoid?.TotalAmount.ToString("N2")</span>
                    </div>
                </div>
            </div>
        </ChildContent>
        <CustomFooter>
            <div class="flex w-full items-center justify-end gap-3 ">
                <button @onclick="() => _isVoidConfirmVisible = false"
                        class="px-6 py-2.5 text-xs font-bold text-slate-400 hover:text-white transition-colors">
                    Close
                </button>
        
                <button @onclick="ConfirmVoid"
                        class="px-8 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[11px] font-black rounded uppercase shadow-lg active:scale-95 transition-all">
                    Confirm Full Void
                </button>
            </div>
        </CustomFooter>
    </Modal>
}

@if (_isItemVoidModalVisible && _itemToVoid != null)
{
    <Modal IsVisible="_isItemVoidModalVisible" Title="Confirm Item Removal" OnClose="() => _isItemVoidModalVisible = false">
        <ChildContent>
            <div class="p-6 space-y-4">
                @* Alert Banner *@
                <div class="bg-amber-50 border-l-4 border-amber-400 p-3 rounded">
                    <div class="flex items-center gap-2 mb-1">
                        <i class="fas fa-exclamation-triangle text-red-600 text-xs"></i>
                        <span class="text-[10px] font-black text-red-600 uppercase">Warning: System Reversal</span>
                    </div>
                    <p class="text-[11px] text-red-500 leading-tight">
                        Removing an item will permanently update the <b>Inventory</b> and <b>Invoice Total</b>. Ensure the physical item is returned to the shelf.
                    </p>
                </div>

                @* Item Detail Display *@
                <div class="bg-slate-50 p-4 rounded-lg border border-slate-200">
                    <div class="flex justify-between items-start mb-2">
                        <div>
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Product to Remove</p>
                            <p class="text-sm font-black text-slate-800">@_itemToVoid.ProductName</p>
                        </div>
                        <div class="text-right">
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Quantity</p>
                            <p class="text-sm font-black text-slate-800">@_itemToVoid.Quantity</p>
                        </div>
                    </div>
                    
                    <div class="mt-4 p-3 bg-white border border-red-100 rounded flex items-center justify-between">
                        <div>
                            <p class="text-[10px] font-bold text-red-400 uppercase">Quantity to Remove</p>
                            <input type="number"
                                   @bind="_quantityToRemove"
                                   @bind:event="oninput"
                                   min="1"
                                   max="@_itemToVoid.Quantity"
                                   onkeypress="return (event.charCode != 8 && event.charCode == 0 || (event.charCode >= 48 && event.charCode <= 57))"
                                   class="w-20 text-lg font-black text-red-600 border-b-2 border-red-600 focus:outline-none" />
                        </div>
                        <div class="text-right">
                            <p class="text-[10px] font-bold text-slate-400 uppercase">Remaining</p>
                            <p class="text-sm font-bold">@(_itemToVoid.Quantity - _quantityToRemove) pcs</p>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col gap-2">
                    <div class="flex gap-2 items-start">
                        <div class="h-4 w-4 rounded-full bg-slate-200 flex items-center justify-center shrink-0">
                            <span class="text-[9px] font-bold">1</span>
                        </div>
                        <p class="text-[10px] text-slate-500 italic">Inventory for this product will increase by <b>@_itemToVoid.Quantity</b>.</p>
                    </div>
                    <div class="flex gap-2 items-start">
                        <div class="h-4 w-4 rounded-full bg-slate-200 flex items-center justify-center shrink-0">
                            <span class="text-[9px] font-bold">2</span>
                        </div>
                        <p class="text-[10px] text-slate-500 italic">The transaction total will be recalculated automatically.</p>
                    </div>
                </div>
            </div>
        </ChildContent>
        <CustomFooter>
            <div class="flex w-full items-center justify-end gap-2">
           
                <button @onclick="() => _isItemVoidModalVisible = false"
                        class="px-4 py-2 text-xs font-bold text-slate-400 hover:text-white transition-colors">
                    Cancel
                </button>

                <button @onclick="ConfirmItemVoid"
                        class="w-auto px-6 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[11px] font-black rounded uppercase shadow-lg active:scale-95 transition-all">
                    Confirm Removal
                </button>
            </div>
        </CustomFooter>
    </Modal>
}

@if (_isHoldInputVisible)
{
    <Modal IsVisible="_isHoldInputVisible" Title="Hold Current Transaction" OnClose="() => _isHoldInputVisible = false">
        <ChildContent>
            <div class="p-6 space-y-4 bg-white">
                <div class="flex items-center gap-4 p-4 bg-amber-50 border border-amber-200 rounded-lg">
                    <i class="fas fa-pause-circle text-amber-600 text-xl"></i>
                    <p class="text-xs text-amber-800 font-medium">This will clear your current cart and save it for later retrieval.</p>
                </div>

                <div class="space-y-2">
