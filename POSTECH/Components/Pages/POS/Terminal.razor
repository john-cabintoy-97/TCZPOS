                    </div>
                </div>
          
                @* 3. Input Field *@
                <div class="space-y-2 pt-2">
                    <label class="text-[10px] font-black text-slate-500 uppercase tracking-[2px]">Reference Name (Required)</label>
                    <input type="text" @bind="_holdReference"
                           @bind:event="oninput"
                           class="w-full bg-white border-2 border-slate-200 p-4 text-slate-800 rounded-lg focus:border-amber-500 focus:ring-2 focus:ring-amber-200 outline-none transition-all shadow-sm"
                           placeholder="e.g., Table 4, Customer John..." />
                </div>
            </div>
        </ChildContent>
        <CustomFooter>
            <div class="flex w-full items-center justify-end gap-2">
           
                <button @onclick="() => _isHoldInputVisible = false"
                        class="px-4 py-2 text-xs font-bold text-slate-400 hover:text-white transition-colors">
                    Cancel
                </button>

                <button @onclick="ConfirmHold"
                        disabled="@string.IsNullOrEmpty(_holdReference)"
                        class="w-auto px-6 py-2.5 bg-green-600 hover:bg-green-700 text-white text-[11px] font-black rounded uppercase shadow-lg active:scale-95 transition-all
                    disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-green-600 disabled:active:scale-100">
                    Confirm Hold
                </button>
            </div>
           
        </CustomFooter>
    </Modal>
}

@if (_isHeldListVisible)
{
    <Modal ShowFooter="false" IsVisible="_isHeldListVisible" Title="Parked Transactions" customCss="!rounded-br-[15px] !rounded-bl-[15px]" OnClose="() => _isHeldListVisible = false">
        <ChildContent>
            <div class="h-[75vh] md:h-[60vh] overflow-y-auto bg-slate-50  flex flex-col">
                
                @if (HeldOrdersList == null || !HeldOrdersList.Any())
                {
                    <div class="flex-1 bg-slate-50 flex flex-col items-center justify-center p-8 text-slate-400">
                        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mb-4">
                            <i class="fas fa-inbox text-2xl"></i>
                        </div>
                        <p class="text-[11px] font-black uppercase tracking-[2px]">No parked orders</p>
                    </div>
                }
                else
                {
                    <div class="p-3 space-y-3  ">
                        @* Reduced padding for mobile screens *@
                        @foreach (var held in HeldOrdersList)
                        {
                            <div class="bg-white border border-slate-200 rounded-2xl shadow-lg overflow-hidden active:scale-[0.98] transition-transform">
                                
                                @* Top Section: Info & Delete *@
                                <div class="p-4 border-b border-dashed border-slate-100">
                                    <div class="flex justify-between items-start">
                                        <div class="space-y-1">
                                            <h4 class="text-xs font-black text-slate-800 uppercase tracking-tight truncate max-w-[180px]">
                                                @held.ReferenceName
                                            </h4>
                                            <div class="flex items-center gap-3 text-[10px] font-bold text-slate-400 uppercase">
                                                <span class="flex items-center gap-1">
                                                    <i class="far fa-clock text-amber-500"></i> @held.HeldAt.ToString("hh:mm tt")
                                                </span>
                                                <span class="flex items-center gap-1">
                                                    <i class="fas fa-shopping-basket text-amber-500"></i> @held.Items.Count
                                                </span>
                                            </div>
                                        </div>
                                        
                                        @* Larger Delete Touch Target *@
                                        <button @onclick="() => DeleteHeldOrder(held.Id)"
                                                class="w-8 h-8 flex items-center justify-center text-slate-300 hover:text-red-500 active:bg-red-50 rounded-full transition-all">
                                            <i class="fas fa-trash-alt text-sm"></i>
                                        </button>
                                    </div>
                                </div>

                                @* Middle Section: Content Preview (Scrollable Row) *@
                                <div class="bg-slate-50/50 p-3">
                                    <div class="flex gap-2 overflow-x-auto pb-1 no-scrollbar">
                                        @foreach (var item in held.Items)
                                        {
                                            <div class="flex-shrink-0 bg-white border border-slate-200 px-3 py-1.5 rounded-lg shadow-sm flex items-center gap-2">
                                                <span class="text-[10px] font-bold text-slate-600">@item.ProductName</span>
                                                <span class="text-[10px] font-black text-amber-600">x @item.Quantity</span>
                                            </div>
                                        }
                                    </div>
                                </div>

                                @* Bottom Section: Full-Width Action *@
                                <button @onclick="() => ResumeHeldOrder(held)"
                                        class="w-full py-4 bg-orange-600 hover:bg-amber-500 text-white hover:text-white text-[11px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-2">
                                    <i class="fas fa-external-link-alt"></i>
                                    Resume This Order
                                </button>

                            </div>
                        }
                    </div>
                }
            </div>
        </ChildContent>
    </Modal>
}


@code {

    #region 1. Initialization
    // --- [ 1. SERVICES & REFERENCES ] ---
    private ElementReference _mainContainer;
    private int _selectedProductIndex = 0;

    // --- [ 2. TRANSACTION STATE ] ---
    private List<CartModels> CartItems = new();
    private bool isLoading = true;
    private bool isTransactionActive = false;
    private string transactionNo = "---";
    private string transactionDate = "---";
    private string _selectedPaymentType = "Cash";

    // --- [ 3. FINANCIAL TOTALS ] ---
    private decimal SubTotal = 0;
    private decimal VatAmount = 0;
    private decimal NetTotal = 0;

    // --- [ 3. DISCOUNT  ] ---
    private CartModels? _selectedRowItem;
    private bool _isDiscountModalVisible = false;
    private string _discountType = "Percent"; // Percent or Fixed
    private decimal _discountValue = 0;
    private decimal TotalDiscount = 0;
    private string? _discountValueString
    {
        get => _discountValue == 0 ? "" : _discountValue.ToString();
        set
        {
            if (decimal.TryParse(value, out var result))
            {
                _discountValue = result;
            }
            else
            {
                _discountValue = 0;
            }
        }
    }
    #endregion
    #region 3. Hold Transaction
    // Hold Transaction
    private bool _isHoldInputVisible = false;
    private bool _isHeldListVisible = false;
    private string _holdReference = "";
    private List<HeldTransactionModel> HeldOrdersList = new();
    private int HeldOrdersCount => HeldOrdersList.Count;
    private async Task OpenHoldModal()
    {
