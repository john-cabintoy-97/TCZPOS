    // --- [ 9. PRODUCT ACTIONS (Search/Scan/Cart) ] ---
    private async Task ProcessBarcode(string code)
    {
        if (string.IsNullOrWhiteSpace(code) || !isTransactionActive) return;

        if (code.Contains("http") || code.Contains("www") || code.Contains("/") || code.Contains("?"))
        {
            await HandleInvalidFormat(code, "URL/QR Link detected. Please scan a product barcode.");
            return;
        }

        if (Regex.IsMatch(code, @"^\d{8,14}$"))
        {
            await SearchProduct(code);
        }
        else if (code.Length < 8)
        {
            await SearchProduct(code);
        }
        else
        {
            await HandleInvalidFormat(code, "Invalid barcode format.");
        }
    }
    private async Task HandleInvalidFormat(string code, string reason)
    {
        Alert.Error(reason);
    
        _barcodeInput = "";
        await Task.Delay(2000);
        await FocusScanner();
    }
    private async Task SearchProduct(string code)
    {
        var product = productService.ProductDisplayList
                        .Select(x => x.Product)
                        .FirstOrDefault(p => p.Barcode == code && p.IsActive);

        if (product != null)
        {
            await AddToCartInternal(product, 1);
            _barcodeInput = "";
        }
        else
        {
            await HandleInvalidBarcode(code);
        }
    }
    private async Task HandleInvalidBarcode(string code)
    {

        Alert.Warning($"Barcode '{code}' not recognized.");

        await Task.Delay(3000);

        await FocusScanner();

    }
    private async Task AddToCartFromSearch(ProductModels product)
    {
        int qty = product.TempQty <= 0 ? 1 : product.TempQty;
        await AddToCartInternal(product, qty);
        product.TempQty = 1;
    }
    private async Task AddToCartInternal(ProductModels product, int qty)
    {
        var existingInCart = CartItems.FirstOrDefault(x => x.ProductId == product.Id);
        int currentCartQty = existingInCart?.Quantity ?? 0;
        int requestedTotal = currentCartQty + qty;

        if (requestedTotal > (product.StockLevel + 0.0001))
        {
            double availableToAdd = Math.Max(0, product.StockLevel - currentCartQty);
        
            string unit = product.Unit.ToLower();
            string formattedStock = product.StockLevel.ToString("0.##");
            string formattedAvailable = availableToAdd.ToString("0.##");

            if (availableToAdd <= 0)
            {
                Alert.Warning($"Limit reached! All {formattedStock} {unit} are already in your cart.");
            }
            else
            {
                Alert.Warning($"Insufficient stock! You can only add {formattedAvailable} more {unit}.");
            }
            return;
        }

        // 3. Update or Add
        if (existingInCart != null)
        {
            existingInCart.Quantity += qty;
            await cartService.UpdateItemAsync(existingInCart);
            Alert.Success($"Updated {product.Name}: +{qty:0.##} {product.Unit} (Total: {existingInCart.Quantity:0.##})");
        }
        else
        {
            var cartItem = new CartModels
            {
                ProductId = product.Id,
                TransactionNo = transactionNo,
                ProductName = product.Name,
                Barcode = product.Barcode,
                Pcode = product.Pcode,
                UnitPrice = product.SellingPrice,
                Quantity = qty,
                DiscountValue = 0,
                DiscountType = "Percent"
            };
        
            await cartService.AddItemAsync(cartItem);
            Alert.Success($"Added {qty:0.##} {product.Unit} of {product.Name}");
        }
    }
