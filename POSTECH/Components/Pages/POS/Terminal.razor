    private async Task IncreaseQty(CartModels item)
    {
        var productInStock = productService.ProductDisplayList
         .FirstOrDefault(p => p.Product.Barcode == item.Barcode)?.Product;

        if (productInStock != null && item.Quantity < productInStock.StockLevel)
        {
            await cartService.SetItemQuantityAsync(item.Id, item.Quantity + 1);
        }
        else
        {
            Alert.Error($"Limit reached. Only {productInStock?.StockLevel ?? 0} available.");
        }
    }
    private async Task ManualUpdateQty(CartModels item, string? newValue)
    {
        if (int.TryParse(newValue, out int newQty) && newQty > 0)
        {
            // Find the product in inventory to check stock
            var productInStock = productService.ProductDisplayList
                .FirstOrDefault(p => p.Product.Barcode == item.Barcode)?.Product;

            if (productInStock != null)
            {
                if (newQty > productInStock.StockLevel)
                {
                    Alert.Error($"Insufficient stock. Max available: {productInStock.StockLevel}");
                    await cartService.SetItemQuantityAsync(item.Id, productInStock.StockLevel);
                }
                else
                {
                    await cartService.SetItemQuantityAsync(item.Id, newQty);
                }
            }
        }
        else
        {
            // If input is invalid (0, negative, or text), reload to revert the UI value
            await LoadCartData();
        }
    }
