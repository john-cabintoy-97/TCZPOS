@page "/inventory/product/new"
@inject ProductServices productService
@inject NavigationManager nav
@using TCZPOS.Components.Scanner
@inject AlertServices Alert

<div class="min-h-screen bg-slate-50/50 pb-2">
    <div class="bg-[#1A252F] border-b border-slate-200 pb-6">
        <div class="mx-8 pt-2 flex items-center  justify-between">
            <div>
                <h2 class="md:text-2xl font-black text-white uppercase tracking-tight">
                    Add <span class="text-orange-600">New Item</span>
                </h2>
                <p class="text-[10px] text-slate-400 uppercase font-bold tracking-widest mt-1">
                    Registry Entry: <span class="text-slate-600">Inventory Management</span>
                </p>
            </div>
            <button @onclick='() => nav.NavigateTo("/inventory/product")'
                    class="md:h-10 md:w-10 h-5 w-5 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-400 hover:text-red-500 hover:border-red-100 transition-all shadow-sm">
                <i class="fas fa-times"></i>
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="mb-6 p-4 rounded-xl border border-red-200 bg-red-50 text-xs font-bold uppercase tracking-widest text-red-600 flex items-center shadow-sm">
            <i class="fas fa-exclamation-triangle mr-3 text-sm"></i> @_errorMessage
        </div>
    }

    @* The Form Container *@
    <div class="m-3 lg:rounded-3xl lg:border lg:border-slate-200 lg:shadow-xl lg:shadow-slate-200/50 ">
        <FormProduct @ref="_productForm" Mode="new" Product="_newProduct" />
    </div>
    @* Action Bar - Floating Style *@
    <div class="mt-3 flex md:mx-4 flex-col-reverse items-center justify-end gap-3 rounded-2xl border border-slate-200 bg-white p-4 md:flex-row md:gap-4 md:shadow-lg">
        <button type="button"
                @onclick='() => nav.NavigateTo("/inventory/product")'
                class="w-full md:w-auto px-8 py-3 text-sm font-bold text-slate-400 uppercase hover:text-slate-600 transition-colors">
            Discard Changes
        </button>

        <button type="button"
                @onclick="Save"
                class="w-full md:w-auto flex items-center justify-center rounded-xl bg-orange-600 px-12 py-4 md:py-3 font-black text-white shadow-lg shadow-orange-200 hover:bg-orange-500 active:scale-95 transition-all">
            @if (productService.IsLoading)
            {
                <i class="fas fa-circle-notch fa-spin mr-2"></i>
            }
            REGISTER PRODUCT
        </button>
    </div>
</div>
@code {
    private ProductModels _newProduct = new();
    private string? _errorMessage;
    private FormProduct? _productForm;

    protected override async void OnInitialized()
    {

        _newProduct.CreatedAt = DateTime.Now;
        _newProduct.Pcode = await productService.GenerateNextPcodeAsync();
    }

    private async Task Save()
    {
        _errorMessage = null;
        var result = await productService.SaveProductAsync(_newProduct);

        if (result.Success)
        {
            Alert.Success("The new product has been successfully registered.");
            _newProduct = new ProductModels();

            _newProduct.CreatedAt = DateTime.Now;
            _newProduct.Pcode = await productService.GenerateNextPcodeAsync();
            _productForm?.ResetAI();
            StateHasChanged();
        }
        else
        {
            _errorMessage = result.Message;
            StateHasChanged();
        }
    }
}