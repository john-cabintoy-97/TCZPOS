@page "/pc-chat"
@implements IDisposable
@inject PairingListenerServices Listener
@using TCZPOS.Components.Modules

<div class="mx-auto flex h-[calc(100vh-64px)] max-w-6xl flex-col space-y-4 overflow-hidden p-4">

    @* Dashboard Header *@
    <div class="grid flex-none grid-cols-1 gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-gray-700 bg-gray-800 p-5 shadow-lg">
            <h3 class="mb-1 text-xs font-bold tracking-widest text-gray-400 uppercase">Controller Status</h3>
            <div class="flex items-center gap-3">
                <div class="h-3 w-3 rounded-full bg-blue-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
                <h2 class="text-xl font-bold text-white">Admin Console</h2>
            </div>
        </div>

        <div class="rounded-2xl border border-gray-700 bg-gray-800 p-5 shadow-lg">
            <h3 class="mb-1 text-xs font-bold tracking-widest text-gray-400 uppercase">Active Connections</h3>
            <div class="flex items-center justify-between">
                <span class="text-3xl font-black text-yellow-500">@connectedCount</span>
                <span class="rounded border border-yellow-500/20 bg-yellow-500/10 px-2 py-1 text-xs text-yellow-500">
                    Devices Online
                </span>
            </div>
        </div>
    </div>

    @* Terminal / Chat Log *@
    <div class="flex h-0 flex-1 flex-col overflow-hidden rounded-2xl border border-gray-700 bg-gray-950 shadow-inner">
        <div class="flex items-center gap-2 border-b border-gray-700 bg-gray-800/50 px-4 py-2">
            <div class="flex gap-1.5">
                <div class="h-3 w-3 rounded-full bg-red-500/20"></div>
                <div class="h-3 w-3 rounded-full bg-yellow-500/20"></div>
                <div class="h-3 w-3 rounded-full bg-green-500/20"></div>
            </div>
            <span class="ml-2 font-mono text-[10px] text-gray-500 uppercase">Broadcast Terminal</span>
        </div>
        
        <div class="custom-scrollbar flex-1 space-y-2 overflow-y-auto p-4 font-mono text-sm">
            @if (!chatLog.Any())
            {
                <p class="text-gray-700 italic">No activity detected on the network...</p>
            }
            @foreach (var msg in chatLog)
            {
                <div class="flex gap-2 border-l-2 @(msg.StartsWith("You") ? "border-blue-500 bg-blue-500/5" : "border-emerald-500 bg-emerald-500/5") px-3 py-1 transition-all">
                    <span class="text-gray-500">[@DateTime.Now.ToString("HH:mm")]</span>
                    <span class="text-gray-200">@msg</span>
                </div>
            }
        </div>
    </div>

    @* Admin Controls *@
    <div class="rounded-2xl border border-gray-700 bg-gray-800 p-4 shadow-xl">
        <div class="flex gap-3">
            <div class="relative flex-1">
                <i class="fas fa-terminal absolute top-4 left-4 text-gray-500"></i>
                <input @bind="pcInput" @bind:event="oninput" @onkeyup="HandleKeyUp"
                       placeholder="Broadcast command to all connected phones..."
                       class="w-full rounded-xl border border-gray-700 bg-gray-900 py-3 pr-4 pl-11 text-white transition-all outline-none placeholder:text-gray-600 focus:border-yellow-500" />
            </div>
            <button @onclick="Send"
                    class="flex items-center gap-2 rounded-xl bg-yellow-500 px-6 font-bold text-gray-900 shadow-lg shadow-yellow-500/20 transition-all hover:bg-yellow-400 active:scale-95">
                <i class="fas fa-paper-plane"></i>
                <span class="hidden md:inline">BROADCAST</span>
            </button>
        </div>
    </div>
</div>

@code {
    private string pcInput = "";
    private List<string> chatLog = new();
    private int connectedCount = 0;

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Send();
    }

    protected override void OnInitialized()
    {
        connectedCount = Listener.GetConnectedCount();
        Listener.OnClientCountChanged += HandleCountChange;
        Listener.OnMessageReceived += HandleIncomingMessage;
    }

    private void HandleCountChange(int count)
    {
        InvokeAsync(() =>
        {
            connectedCount = count;
            StateHasChanged();
        });
    }

    private void HandleIncomingMessage(string device, string message)
    {
        InvokeAsync(() =>
        {
            chatLog.Add($"{device}: {message}");
            StateHasChanged();
        });
    }

    private async Task Send()
    {
        if (string.IsNullOrWhiteSpace(pcInput)) return;
        await Listener.BroadcastToAll(pcInput);
        
        chatLog.Add($"You (Admin): {pcInput}");
        pcInput = "";
    }

    public void Dispose()
    {
        Listener.OnClientCountChanged -= HandleCountChange;
        Listener.OnMessageReceived -= HandleIncomingMessage;
    }
}