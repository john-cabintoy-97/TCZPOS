<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TCZPOS.Xaml.CameraNativePage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:extension="clr-namespace:TCZPOS.Components.Extension"
             BackgroundColor="Black">
    <Grid>
        <!-- 1. Added Opacity="0" to start hidden so hardware can settle -->
        <toolkit:CameraView x:Name="cameraView" 
                            HorizontalOptions="Fill" 
                            VerticalOptions="Fill"
                            Opacity="0" />

        <VerticalStackLayout HorizontalOptions="Center" 
                         VerticalOptions="Start" 
                         Margin="0,110,0,0" 
                         Spacing="5"
                         InputTransparent="True">
            <Label Text="SCAN PRODUCT LABEL" 
               TextColor="Cyan"
               FontSize="18"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center" />
            <Label Text="Align text inside the frame for better accuracy" 
               TextColor="White"
               FontSize="13"
               HorizontalTextAlignment="Center"
               Opacity="0.8" />
        </VerticalStackLayout>
        
        <!-- Header: Flash Toggle -->
        <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Start" Margin="20,50">
            <Button x:Name="btnFlash"
                Text="{x:Static extension:IconFont.FlashOff}"
                FontFamily="MaterialIcons"
                FontSize="24"
                BackgroundColor="#33FFFFFF"
                TextColor="White"
                HeightRequest="50"
                WidthRequest="50"
                CornerRadius="25"
                Clicked="OnFlashClicked" />
        </HorizontalStackLayout>
        
        <!-- Viewfinder -->
        <Border Stroke="Cyan" 
            StrokeThickness="2" 
            HeightRequest="300" 
            WidthRequest="300" 
            HorizontalOptions="Center" 
            VerticalOptions="Center"
            StrokeShape="RoundRectangle 30"
            InputTransparent="True">
            <Label Text="Focusing..." 
               TextColor="#44FFFFFF" 
               FontSize="12" 
               VerticalOptions="End" 
               HorizontalOptions="Center" 
               Margin="0,0,0,10"/>
        </Border>

        <!-- Footer Controls -->
        <Grid ColumnDefinitions="*, *, *" VerticalOptions="End" Margin="20,0,20,50">
            <!-- Browse Button -->
            <Button Grid.Column="0"
                    Text="{x:Static extension:IconFont.Gallery}"
                    FontFamily="MaterialIcons"
                    FontSize="24"
                    BackgroundColor="#33FFFFFF"
                    TextColor="White"
                    HeightRequest="60"
                    WidthRequest="60"
                    CornerRadius="30"
                    Clicked="OnBrowseClicked" />

            <!-- Capture Button -->
            <Button Grid.Column="1"
                    Text="{x:Static extension:IconFont.Camera}"
                    FontFamily="MaterialIcons"
                    FontSize="36"
                    BackgroundColor="Orange"
                    TextColor="White"
                    HeightRequest="80"
                    WidthRequest="80"
                    CornerRadius="40"
                    HorizontalOptions="Center"
                    Clicked="OnCaptureClicked" />

            <!-- Close Button -->
            <Button Grid.Column="2"
                    Text="{x:Static extension:IconFont.Close}"
                    FontFamily="MaterialIcons"
                    FontSize="24"
                    BackgroundColor="#33FFFFFF"
                    TextColor="White"
                    HeightRequest="60"
                    WidthRequest="60"
                    CornerRadius="30"
                    Clicked="OnCloseClicked" />
        </Grid>
        <BoxView x:Name="shutterOverlay"
             BackgroundColor="White"
             Opacity="0"
             InputTransparent="True"
             HorizontalOptions="Fill"
             VerticalOptions="Fill" />
        
        <ActivityIndicator x:Name="loadingIndicator"
                           IsRunning="False" 
                           IsVisible="False"
                           Color="Cyan"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Scale="2" />
    </Grid>
</ContentPage>